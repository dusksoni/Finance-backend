// ==========================
// 🔧 Prisma Configuration
// ==========================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================
// 📦 Enums
// ==========================

enum EmployeeRole {
  FINANCE_MANAGER
  SALES_EXECUTIVE
  SUPPORT_AGENT
}

// ==========================
// 📍 Location Models
// ==========================
model State {
  id        String     @id @default(uuid())
  name      String     @unique
  city      City[]
  stateCode String     @default("00")
  employees Employee[]
  users     User[]
  Region    Region[]
}

model City {
  id      String @id @default(uuid())
  name    String @unique
  stateId String
  state   State  @relation(fields: [stateId], references: [id])

  employees Employee[]
  users     User[]
  Region    Region[]
}

model Region {
  id      String @id @default(uuid())
  name    String
  stateId String
  cityId  String

  state     State      @relation(fields: [stateId], references: [id])
  city      City       @relation(fields: [cityId], references: [id])
  users     User[]
  branches  Branch[]
  employees Employee[]
}

// ==========================
// 👤 Identity & Roles
// ==========================

model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees              Employee[]
  loginActivities        LoginActivity[]
  terminationRequest     TerminationRequest[]
  actionLogs             ActionLog[]
  users                  User[]
  loans                  Loan[]
  ceaseHistoriesAssigned CeaseHistory[]        @relation("AssignedByAdmin")
  ceaseHistoriesReleased  CeaseHistory[]        @relation("ReleasedByAdmin")
  requestedUpdates       UserUpdateRequest[]   @relation("RequestedByAdmin")
  verifiedPayments       Payment[]             @relation("VerifiedByAdmin")
  payments               Payment[]
  ceaseContactAttempts   CeaseContactAttempt[]
  // CeaseHistory           CeaseHistory[]
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  permissions String[]
  employees   Employee[]
}

model Employee {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  photoUrlId String?

  photoUrl      File? @relation("Photo", fields: [photoUrlId], references: [id])

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  adminId String?
  admin   Admin?  @relation(fields: [adminId], references: [id])

  stateId String?
  cityId  String?
  state   State?  @relation(fields: [stateId], references: [id])
  city    City?   @relation(fields: [cityId], references: [id])

  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  isDeleted                Boolean               @default(false)
  isBlocked                Boolean               @default(false)
  branchId                 String?
  branch                   Branch?               @relation(fields: [branchId], references: [id])
  users                    User[]
  loginActivities          LoginActivity[]
  actionLogs               ActionLog[]
  terminationRequest       TerminationRequest[]
  loans                    Loan[]
  verifiedPayments         Payment[]             @relation("VerifiedByEmployee")
  requestedUpdates         UserUpdateRequest[]   @relation("RequestedByEmployee")
  ceaseHistoriesAssigned   CeaseHistory[]        @relation("AssignedByEmployee")
  ceaseHistoriesAssignedTo CeaseHistory[]        @relation("CeaseAssignedTo")
  ceaseHistoriesCeasedBy   CeaseHistory[]        @relation("CeasedBy")
  ceaseHistoriesReleased    CeaseHistory[]        @relation("ReleasedByEmployee")
  payments                 Payment[]
  ceaseContactAttempts     CeaseContactAttempt[]
  // CeaseHistory             CeaseHistory[]
}

model LoginActivity {
  id                 String              @id @default(uuid())
  adminId            String?
  employeeId         String?
  role               String
  deviceName         String?
  deviceType         String?
  latitude           Float?
  longitude          Float?
  ipAddress          String?
  loggedInAt         DateTime            @default(now())
  userUpdateRequests UserUpdateRequest[]
  admin              Admin?              @relation(fields: [adminId], references: [id])
  employee           Employee?           @relation(fields: [employeeId], references: [id])
  actionLogs         ActionLog[]
}

model ActionLog {
  id              String  @id @default(uuid())
  adminId         String?
  employeeId      String?
  loginActivityId String?

  action    String
  targetId  String?
  table     String?
  metadata  Json?
  createdAt DateTime @default(now())

  admin         Admin?         @relation(fields: [adminId], references: [id])
  employee      Employee?      @relation(fields: [employeeId], references: [id])
  loginActivity LoginActivity? @relation(fields: [loginActivityId], references: [id])
}

// ==========================
// 👥 Users
// ==========================
model User {
  id                 String           @id @default(uuid())
  firstName          String           @default("")
  middleName         String           @default("")
  lastName           String           @default("")
  relationFirstName  String           @default("")
  relationMiddleName String           @default("")
  relationLastName   String           @default("")
  dateOfBirth        DateTime         @default(now())
  maritalStatus      String?          @default("")
  email              String?          @unique
  phone              String?          @unique
  createdBy          String?
  adminId            String?
  employeeId         String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  isBlocked          Boolean          @default(false)
  isDefaulter        Boolean          @default(false)
  qualification      String?
  profession         String?
  address            String?
  cityText           String?
  country            String?
  creditScore        Int?
  proofOfIncome      String?
  stateId            String?
  cityId             String?
  regionId           String?
  photoId            String?
  genderId           String?
  relationTypeId     String?
  addressCategoryId  String?
  state              State?           @relation(fields: [stateId], references: [id])
  city               City?            @relation(fields: [cityId], references: [id])
  pincode            Int?
  region             Region?          @relation(fields: [regionId], references: [id])
  addressCategory    AddressCategory? @relation(fields: [addressCategoryId], references: [id])
  relationType       RelationType?    @relation(fields: [relationTypeId], references: [id])
  gender             Gender?          @relation(fields: [genderId], references: [id])
  photo              File?            @relation("Photo", fields: [photoId], references: [id])
  admin              Admin?           @relation(fields: [adminId], references: [id])
  employee           Employee?        @relation(fields: [employeeId], references: [id])

  guarantorReputationScore Int? // Calculated based on the loans they guaranteed
  totalGuaranteedLoans     Int? // How many loans user has guaranteed
  successfulGuarantees     Int? // Loans where borrower paid on time
  failedGuarantees         Int? // Loans where borrower defaulted
  guarantorLoans           LoanGuarantor[]     @relation("UserAsGuarantor")
  loans                    Loan[]
  photoIds                 PhotoID[]
  proofOfIncomeImages      File[]              @relation("ProofOfIncomeImages")
  updateRequests           UserUpdateRequest[]
}

model UserUpdateRequest {
  id                    String         @id @default(uuid())
  userId                String
  changes               Json
  status                String         @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedByAdminId     String?
  updatedAt             DateTime?
  rejectedReason        String?
  loginActivityId       String?
  requestedByAdminId    String?
  requestedByEmployeeId String?
  user                  User           @relation(fields: [userId], references: [id])
  loginActivity         LoginActivity? @relation(fields: [loginActivityId], references: [id])
  requestedByAdmin      Admin?         @relation("RequestedByAdmin", fields: [requestedByAdminId], references: [id])
  requestedByEmployee   Employee?      @relation("RequestedByEmployee", fields: [requestedByEmployeeId], references: [id])
}

model RelationType {
  id        String   @id @default(uuid())
  name      String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model AddressCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model Gender {
  id        String   @id @default(uuid())
  name      String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  regionId  String
  address   String?
  pincode   Int?
  latitude  Float?
  longitude Float?
  phone     String?
  email     String?
  isDeleted Boolean? @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  region    Region     @relation(fields: [regionId], references: [id])
  loans     Loan[]
  employees Employee[]

  @@unique([name, regionId]) // Prevent duplicate branch names in the same region
}

model PhotoID {
  id            String @id @default(uuid())
  userId        String
  photoIdTypeId String
  photoIdNumber String @unique

  user        User        @relation(fields: [userId], references: [id])
  photoIdType PhotoIdType @relation(fields: [photoIdTypeId], references: [id])
  images      File[]      @relation("PhotoIDImages")
}

model PhotoIdType {
  id           String    @id @default(uuid())
  name         String    @unique
  description  String
  minLength    Int
  maxLength    Int
  numberTypeEg String
  validation   String?
  photoIds     PhotoID[]
}

// ==========================
// 💳 Loan & Payments
// ==========================

model LoanType {
  id          String  @id @default(uuid())
  name        String  @unique
  label       String
  description String?
  rules       Json?

  loans Loan[]
}

model LoanGuarantor {
  id          String @id @default(uuid())
  loanId      String
  guarantorId String

  performanceScore Float? // Optional: Custom logic
  isFlagged        Boolean? @default(false) // Whether to warn this guarantor
  notes            String? // For remarks like "Defaulted twice", etc.

  loan      Loan @relation(fields: [loanId], references: [id])
  guarantor User @relation("UserAsGuarantor", fields: [guarantorId], references: [id])

  createdAt DateTime @default(now())
}

enum FileStatus {
  INITIATED // File created, awaiting further action
  IN_PROGRESS // Processing underway (verification, evaluation)
  PENDING_APPROVAL // Waiting for final approval
  APPROVED // Approved but not yet disbursed
  DISBURSED // Loan amount given to the user
  ACTIVE // Loan is live, repayment ongoing
  OVERDUE // Payment due is late
  DEFAULTED // Repeated missed payments / declared default
  CEASED_INITIATED // Product/assets ceased due to non-payment
  CEASED // Product/assets ceased due to non-payment
  RELEASED // Product/assets returned to customer
  CLOSED // Loan fully repaid and file closed
  REJECTED // Application rejected before approval
  CANCELLED // File manually cancelled before any disbursal
  LEGAL_ACTION // Under legal processing
  WRITTEN_OFF // Loan marked as bad debt/loss
  UNDER_COLLECTION // Sent to recovery team or agents
  FORECLOSURE_IN_PROGRESS // Under foreclosure process
  FORECLOSED // Foreclosure completed
}

model Loan {
  id            String    @id @default(uuid())
  fileNo        String    @unique
  loanTypeId    String
  loanType      LoanType  @relation(fields: [loanTypeId], references: [id])
  disbursedDate DateTime?
  agreementDate DateTime?

  productAmount        Float?
  downPayment          Float?
  principalLoanAmount  Float
  interestAmount       Float
  totalAmount          Float
  totalPaidPrincipal   Float      @default(0)
  totalPaidInterest    Float      @default(0)
  totalPaidFine        Float      @default(0)
  totalPaidAmount      Float      @default(0)
  monthlyPayableAmount Float
  pendingAmount        Float
  rtoCharges           Float?
  processingCharges    Float?
  otherCharges         Float?
  ourPaymentType       String?
  interestRate         Float
  interestType         String?
  penaltyPercentage    Float
  tenureMonths         Int
  startDate            DateTime
  endDate              DateTime
  dueDay               Int        @default(5)
  paymentFrequency     String?    @default("MONTHLY")
  fileStatus           FileStatus @default(INITIATED)
  isClosed             Boolean    @default(false)
  isDefaulted          Boolean    @default(false)
  totalDelayDays       Int        @default(0)
  defaultReason        String?
  insuranceAmount      Float?
  insuranceDate        DateTime?
  insuranceValidTill   DateTime?
  insuranceAlert       Boolean    @default(false)
  insuranceNumber      String?
  insuranceCompany     String?
  comment              String?
  isForeclosed         Boolean    @default(false)
  foreclosedAt         DateTime?
  createdBy            String?
  adminId              String?
  employeeId           String?
  userId               String
  branchId             String?

  branch         Branch?          @relation(fields: [branchId], references: [id])
  admin          Admin?           @relation(fields: [adminId], references: [id])
  employee       Employee?        @relation(fields: [employeeId], references: [id])
  user           User             @relation(fields: [userId], references: [id])
  emi            EMI[]
  payments       Payment[]
  ceaseHistories CeaseHistory[]
  guarantors     LoanGuarantor[]
  twoWheelerLoan TwoWheelerLoan?
  agriLoan       AgricultureLoan?
  msmeLoan       MSMELoan?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EMI {
  id          String   @id @default(uuid())
  loanId      String
  paymentFor  DateTime
  paymentDate DateTime @default(now())

  emiPayAmount    Decimal @default(0)
  principalAmt    Decimal @default(0)
  interestAmt     Decimal @default(0)
  amountPaidSoFar Decimal @default(0)
  finePaid        Decimal @default(0)
  totalPaid       Decimal @default(0)
  principalPaid   Decimal @default(0)
  interestPaid    Decimal @default(0)

  status String @default("UNPAID")

  isForeclosure        Boolean   @default(false)
  isDelayed            Boolean   @default(false)
  delayDays            Int?
  fineAmount           Float?
  verified             Boolean   @default(false)
  verifiedAt           DateTime?
  verifiedByAdminId    String?
  verifiedByEmployeeId String?

  loan      Loan     @relation(fields: [loanId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  payments Payment[] // one-to-many: all payments linked to this EMI
}

model Payment {
  id                   String       @id @default(uuid())
  loanId               String
  emiId                String?
  amount               Decimal?     @default(0)
  paymentDate          DateTime     @default(now())
  paymentMode          PaymentMode?
  transactionId        String?
  status               String       @default("PENDING") // PENDING, PAID, UNVERIFIED
  isForeclosure        Boolean      @default(false)
  verified             Boolean      @default(false)
  verifiedAt           DateTime?
  verifiedByAdminId    String?
  verifiedByEmployeeId String?
  metadata             Json?
  adminId              String?
  employeeId           String?
  emi                  EMI?         @relation(fields: [emiId], references: [id])
  verifiedByAdmin      Admin?       @relation("VerifiedByAdmin", fields: [verifiedByAdminId], references: [id])
  verifiedByEmployee   Employee?    @relation("VerifiedByEmployee", fields: [verifiedByEmployeeId], references: [id])
  admin                Admin?       @relation(fields: [adminId], references: [id])
  employee             Employee?    @relation(fields: [employeeId], references: [id])
  loan                 Loan         @relation(fields: [loanId], references: [id])
}

enum ContactType {
  CALL
  VISIT
  WHATSAPP
  SMS
  OTHER
}

enum CallOutcome {
  PICKED
  UNREACHABLE
  SWITCHED_OFF
  BUSY
  NO_ANSWER
  WRONG_NUMBER
  NOT_APPLICABLE
}

// ===== Models =====

model CeaseHistory {
  id                   String    @id @default(uuid())
  loanId               String
  assignedByAdminId    String?
  assignedByEmployeeId String?
  assignedToId         String?
  ceasedById           String?
  ceaseDate            DateTime?
  actualCeaseDate      DateTime?
  ceaseLat             Float?
  ceaseLng             Float?
  ceaseAddress         String?

  comment        String?
  releaseDate    DateTime?
  releaseReason  String?
  releaseNotes   String?
  status         String    @default("PENDING") // PENDING, COMPLETED, RELEASED
  priority       String    @default("MEDIUM") // HIGH, MEDIUM, LOW
  dueDate        DateTime?
  assetCondition String?

  releasedByAdminId    String?
  releasedByEmployeeId String?

  // relations
  loan               Loan      @relation(fields: [loanId], references: [id])
  assignedByAdmin    Admin?    @relation("AssignedByAdmin", fields: [assignedByAdminId], references: [id])
  assignedByEmployee Employee? @relation("AssignedByEmployee", fields: [assignedByEmployeeId], references: [id])
  releasedByAdmin    Admin?    @relation("ReleasedByAdmin", fields: [releasedByAdminId], references: [id])
  releasedByEmployee Employee? @relation("ReleasedByEmployee", fields: [releasedByEmployeeId], references: [id])
  assignedTo         Employee? @relation("CeaseAssignedTo", fields: [assignedToId], references: [id])
  ceasedBy           Employee? @relation("CeasedBy", fields: [ceasedById], references: [id])

  files        File[] @relation("CeaseFiles")
  releaseFiles File[] @relation("ReleaseFiles")

  // NEW: detailed log of attempts
  contactAttempts CeaseContactAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// NEW: separate attempts table
model CeaseContactAttempt {
  id             String @id @default(uuid())
  ceaseHistoryId String

  contactAt           DateTime     @default(now())
  contactType         ContactType  @default(CALL)
  callOutcome         CallOutcome?
  summary             String?
  spokeTo             String?
  createdByAdminId    String?
  createdByEmployeeId String?
  durationSeconds     Int?
  ceaseHistory        CeaseHistory @relation(fields: [ceaseHistoryId], references: [id])
  createdByAdmin      Admin?       @relation(fields: [createdByAdminId], references: [id])
  createdByEmployee   Employee?    @relation(fields: [createdByEmployeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PaymentMode {
  ONLINE
  CHEQUE
  UPI
  CASH
}

// ==========================
// 🚘 Loan Sub-Types
// ==========================

model TwoWheelerLoan {
  id          String  @id @default(uuid())
  loanId      String  @unique
  vehicleName String?

  brandId                 String
  modelId                 String
  variantId               String?
  hypothecationTerminated Boolean              @default(false)
  terminationRequests     TerminationRequest[]
  registrationNumber      String               @unique
  chassisNumber           String               @unique
  engineNumber            String
  rcNumber                String?

  brand   VehicleBrand    @relation(fields: [brandId], references: [id])
  model   VehicleModel    @relation(fields: [modelId], references: [id])
  variant VehicleVariant? @relation(fields: [variantId], references: [id])

  loan Loan @relation(fields: [loanId], references: [id])
}

model VehicleBrand {
  id              String           @id @default(uuid())
  name            String           @unique
  models          VehicleModel[]
  twoWheelerLoans TwoWheelerLoan[]
}

model VehicleModel {
  id              String           @id @default(uuid())
  name            String
  brandId         String
  brand           VehicleBrand     @relation(fields: [brandId], references: [id])
  variants        VehicleVariant[]
  twoWheelerLoans TwoWheelerLoan[]
}

model VehicleVariant {
  id              String           @id @default(uuid())
  name            String
  modelId         String
  model           VehicleModel     @relation(fields: [modelId], references: [id])
  twoWheelerLoans TwoWheelerLoan[]
}

model AgricultureLoan {
  id          String  @id @default(uuid())
  loanId      String  @unique
  equipmentId String
  usageArea String?
  isSeasonal  Boolean @default(false)

  equipment Equipment  @relation(fields: [equipmentId], references: [id])
  // usageArea UsageArea? @relation(fields: [usageAreaId], references: [id])

  loan Loan @relation(fields: [loanId], references: [id])
}

model Equipment {
  id    String            @id @default(uuid())
  name  String            @unique
  loans AgricultureLoan[]
}

// model UsageArea {
//   id    String            @id @default(uuid())
//   name  String            @unique
//   loans AgricultureLoan[]
// }

model MSMELoan {
  id                 String  @id @default(uuid())
  loanId             String  @unique
  businessName       String
  registrationNumber String  @unique
  businessType       String
  monthlyRevenue     Float
  gstNumber          String?

  loan Loan @relation(fields: [loanId], references: [id])
}

// ==========================
// 📑 Termination / Files
// ==========================

model TerminationRequest {
  id            String   @id @default(uuid())
  regnNo        String
  chassisNo     String
  terminationDt DateTime
  docFileId     String?
  docFile       File?    @relation(fields: [docFileId], references: [id])
  encryptedData String
  response      Json?
  status        String?
  errorMessage  String?

  createdAt        DateTime @default(now())
  createdBy        String?
  twoWheelerLoanId String?
  adminId          String?
  employeeId       String?

  admin          Admin?          @relation(fields: [adminId], references: [id])
  employee       Employee?       @relation(fields: [employeeId], references: [id])
  twoWheelerLoan TwoWheelerLoan? @relation(fields: [twoWheelerLoanId], references: [id])
}

model File {
  id                 String               @id @default(uuid())
  url                String
  publicId           String
  resourceType       String
  format             String
  createdAt          DateTime             @default(now())
  terminationRequest TerminationRequest[]

  ceaseHistories        CeaseHistory[] @relation("CeaseFiles") // Evidence for cease events
  releaseCeaseHistories CeaseHistory[] @relation("ReleaseFiles") // Evidence for release events

  photo               User[]    @relation("Photo")
  proofOfIncomeImages User[]    @relation("ProofOfIncomeImages")
  photoIDImages       PhotoID[] @relation("PhotoIDImages")
  employees         Employee[] @relation("Photo")
}
