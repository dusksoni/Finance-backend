// ==========================
// 🔧 Prisma Configuration
// ==========================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================
// 📦 Enums
// ==========================

enum EmployeeRole {
  FINANCE_MANAGER
  SALES_EXECUTIVE
  SUPPORT_AGENT
}

// ==========================
// 📍 Location Models
// ==========================
model State {
  id            String        @id @default(uuid())
  name          String        @unique
  city          City[]
  stateCode     String        @default("00")
  employees     Employee[]
  Region        Region[]
  userAddresses UserAddress[]
}

model City {
  id            String        @id @default(uuid())
  name          String        @unique
  stateId       String
  state         State         @relation(fields: [stateId], references: [id])
  employees     Employee[]
  Region        Region[]
  userAddresses UserAddress[]
}

model Region {
  id      String @id @default(uuid())
  name    String
  stateId String
  cityId  String

  state     State      @relation(fields: [stateId], references: [id])
  city      City       @relation(fields: [cityId], references: [id])
  users     User[]
  branches  Branch[]
  employees Employee[]
}

// ==========================
// 👤 Identity & Roles
// ==========================

model Admin {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  password          String
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  employees                  Employee[]
  loginActivities            LoginActivity[]
  terminationRequest         TerminationRequest[]
  actionLogs                 ActionLog[]
  users                      User[]
  loans                      Loan[]
  approvedLoans              Loan[]                 @relation("LoanApprovedByAdmin")
  seizedHistoriesAssigned    SeizedHistory[]        @relation("AssignedByAdmin")
  seizedHistoriesReleased    SeizedHistory[]        @relation("ReleasedByAdmin")
  requestedUpdates           UserUpdateRequest[]    @relation("RequestedByAdmin")
  verifiedPayments           Payment[]              @relation("VerifiedByAdmin")
  payments                   Payment[]
  seizedContactAttempts      SeizedContactAttempt[]
  approvedForecloseRequests  ForecloseRequest[]     @relation("ForecloseApprovedByAdmin")
  requestedForecloseRequests ForecloseRequest[]     @relation("ForecloseRequestedByAdmin")
  loanApplicationDrafts      LoanApplicationDraft[]
  userApplicationDrafts      UserApplicationDraft[]
  appConfigsUpdated          AppConfig[]            @relation("AppConfigUpdatedByAdmin")
  grievancesCreated          GrievanceTicket[]      @relation("GrievanceCreatedByAdmin")
  grievancesAssigned         GrievanceTicket[]      @relation("GrievanceAssignedByAdmin")
  grievancesResolved         GrievanceTicket[]      @relation("GrievanceResolvedByAdmin")
  grievanceComments          GrievanceComment[]     @relation("GrievanceCommentCreatedByAdmin")
  collectionCasesCreated     CollectionCase[]       @relation("CollectionCaseCreatedByAdmin")
  collectionCasesAssigned    CollectionCase[]       @relation("CollectionCaseAssignedByAdmin")
  collectionCasesClosed      CollectionCase[]       @relation("CollectionCaseClosedByAdmin")
  collectionActionsCreated   CollectionAction[]     @relation("CollectionActionCreatedByAdmin")

  // Phase 2: Approval Matrix
  approvalMatrices           ApprovalMatrix[]
  approvalRequestsCreated    ApprovalRequest[]      @relation("ApprovalRequestedByAdmin")
  approvalVotes              ApprovalVote[]         @relation("ApprovalVoteByAdmin")
  overrideLogs               OverrideLog[]          @relation("OverrideByAdmin")
  overrideSupervised         OverrideLog[]          @relation("OverrideSupervisor")

  // Phase 3: KYC
  kycVerifications           KYCRecord[]            @relation("KYCVerifiedByAdmin")
  kycDocVerifications        KYCDocument[]          @relation("KYCDocVerifiedByAdmin")
  kycFlagResolutions         KYCRiskFlag[]          @relation("KYCFlagResolvedByAdmin")
  blacklistAdded             BlacklistEntry[]       @relation("BlacklistAddedBy")
  blacklistRemoved           BlacklistEntry[]       @relation("BlacklistRemovedBy")

  // Phase 4: Consent
  consentTemplatesCreated    ConsentTemplate[]

  // Phase 5: Restructuring
  restructuringRequestsCreated  RestructuringRequest[] @relation("RestructureRequestedByAdmin")
  restructuringRequestsApproved RestructuringRequest[] @relation("RestructureApprovedByAdmin")
  waiverRequestsCreated         WaiverRequest[]        @relation("WaiverRequestedByAdmin")
  waiverRequestsApproved        WaiverRequest[]        @relation("WaiverApprovedByAdmin")

  // Phase 6: Reconciliation
  dayEndSubmissions          DayEndClosing[]        @relation("DayEndSubmittedByAdmin")
  dayEndApprovals            DayEndClosing[]        @relation("DayEndApprovedByAdmin")
  bankRecons                 BankReconciliation[]   @relation("BankReconByAdmin")
  suspenseResolutions        SuspenseAccount[]      @relation("SuspenseResolvedByAdmin")
  reversalRequestsCreated    ReversalRequest[]      @relation("ReversalRequestedByAdmin")
  reversalRequestsApproved   ReversalRequest[]      @relation("ReversalApprovedByAdmin")

  // Phase 7: Collections enhancements
  promisesToPayCreated       PromiseToPay[]         @relation("PTPCreatedByAdmin")
  legalActionsCreated        LegalAction[]          @relation("LegalActionCreatedByAdmin")

  // Phase 8: Collateral
  collateralsCreated         CollateralRecord[]     @relation("CollateralCreatedByAdmin")
  valuationsCreated          CollateralValuation[]  @relation("ValuationCreatedByAdmin")

  // Phase 9: Partners
  channelPartnersCreated     ChannelPartner[]
  partnerPayoutsProcessed    PartnerPayout[]        @relation("PayoutProcessedByAdmin")

  // Phase 10: Reports
  savedReportsCreated        SavedReport[]          @relation("ReportCreatedByAdmin")
  reportRunsTriggered        ReportRun[]            @relation("ReportRunByAdmin")

  // Phase 11: Automation
  automationRulesCreated     AutomationRule[]
  tasksAssigned              TaskQueue[]            @relation("TaskAssignedToAdmin")
  tasksCreated               TaskQueue[]            @relation("TaskCreatedByAdmin")

  // Phase 12: Compliance
  legalHoldsHeld             LegalHold[]            @relation("LegalHoldHeldBy")
  legalHoldsReleased         LegalHold[]            @relation("LegalHoldReleasedBy")
  piiAccessLogs              PIIAccessLog[]         @relation("PIIAccessByAdmin")
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  permissions String[]
  employees   Employee[]
}

model Employee {
  id         String  @id @default(uuid())
  name       String
  email      String  @unique
  password   String
  photoUrlId String?

  photoUrl File? @relation("Photo", fields: [photoUrlId], references: [id])

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  adminId String?
  admin   Admin?  @relation(fields: [adminId], references: [id])

  stateId String?
  cityId  String?
  state   State?  @relation(fields: [stateId], references: [id])
  city    City?   @relation(fields: [cityId], references: [id])

  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  isDeleted                  Boolean                @default(false)
  isBlocked                  Boolean                @default(false)
  branchId                   String?
  branch                     Branch?                @relation(fields: [branchId], references: [id])
  users                      User[]
  loginActivities            LoginActivity[]
  actionLogs                 ActionLog[]
  terminationRequest         TerminationRequest[]
  loans                      Loan[]
  approvedLoans              Loan[]                 @relation("LoanApprovedByEmployee")
  verifiedPayments           Payment[]              @relation("VerifiedByEmployee")
  requestedUpdates           UserUpdateRequest[]    @relation("RequestedByEmployee")
  seizedHistoriesAssigned    SeizedHistory[]        @relation("AssignedByEmployee")
  seizedHistoriesAssignedTo  SeizedHistory[]        @relation("SeizedAssignedTo")
  seizedHistoriesSeizedBy    SeizedHistory[]        @relation("SeizedBy")
  seizedHistoriesReleased    SeizedHistory[]        @relation("ReleasedByEmployee")
  payments                   Payment[]
  seizedContactAttempts      SeizedContactAttempt[]
  approvedForecloseRequests  ForecloseRequest[]     @relation("ForecloseApprovedByEmployee")
  requestedForecloseRequests ForecloseRequest[]     @relation("ForecloseRequestedByEmployee")
  loanApplicationDrafts      LoanApplicationDraft[]
  userApplicationDrafts      UserApplicationDraft[]
  appConfigsUpdated          AppConfig[]            @relation("AppConfigUpdatedByEmployee")
  grievancesCreated          GrievanceTicket[]      @relation("GrievanceCreatedByEmployee")
  grievancesAssignedBy       GrievanceTicket[]      @relation("GrievanceAssignedByEmployee")
  grievancesAssignedTo       GrievanceTicket[]      @relation("GrievanceAssignedToEmployee")
  grievancesResolved         GrievanceTicket[]      @relation("GrievanceResolvedByEmployee")
  grievanceComments          GrievanceComment[]     @relation("GrievanceCommentCreatedByEmployee")
  collectionCasesCreated     CollectionCase[]       @relation("CollectionCaseCreatedByEmployee")
  collectionCasesAssignedBy  CollectionCase[]       @relation("CollectionCaseAssignedByEmployee")
  collectionCasesAssignedTo  CollectionCase[]       @relation("CollectionCaseAssignedToEmployee")
  collectionCasesClosed      CollectionCase[]       @relation("CollectionCaseClosedByEmployee")
  collectionActionsCreated   CollectionAction[]     @relation("CollectionActionCreatedByEmployee")

  // Phase 2: Approval Matrix
  approvalRequestsCreated    ApprovalRequest[]      @relation("ApprovalRequestedByEmployee")
  approvalVotes              ApprovalVote[]         @relation("ApprovalVoteByEmployee")
  overrideLogs               OverrideLog[]          @relation("OverrideByEmployee")

  // Phase 3: KYC
  kycVerifications           KYCRecord[]            @relation("KYCVerifiedByEmployee")
  kycDocVerifications        KYCDocument[]          @relation("KYCDocVerifiedByEmployee")
  kycFlagResolutions         KYCRiskFlag[]          @relation("KYCFlagResolvedByEmployee")

  // Phase 5: Restructuring
  restructuringRequestsCreated  RestructuringRequest[] @relation("RestructureRequestedByEmployee")
  restructuringRequestsApproved RestructuringRequest[] @relation("RestructureApprovedByEmployee")
  waiverRequestsCreated         WaiverRequest[]        @relation("WaiverRequestedByEmployee")
  waiverRequestsApproved        WaiverRequest[]        @relation("WaiverApprovedByEmployee")

  // Phase 6: Reconciliation
  dayEndSubmissions          DayEndClosing[]        @relation("DayEndSubmittedByEmployee")
  bankRecons                 BankReconciliation[]   @relation("BankReconByEmployee")
  suspenseResolutions        SuspenseAccount[]      @relation("SuspenseResolvedByEmployee")
  reversalRequestsCreated    ReversalRequest[]      @relation("ReversalRequestedByEmployee")
  reversalRequestsApproved   ReversalRequest[]      @relation("ReversalApprovedByEmployee")

  // Phase 7: Collections enhancements
  promisesToPayCreated       PromiseToPay[]         @relation("PTPCreatedByEmployee")
  legalActionsCreated        LegalAction[]          @relation("LegalActionCreatedByEmployee")

  // Phase 8: Collateral
  collateralsCreated         CollateralRecord[]     @relation("CollateralCreatedByEmployee")
  valuationsCreated          CollateralValuation[]  @relation("ValuationCreatedByEmployee")

  // Phase 10: Reports
  savedReportsCreated        SavedReport[]          @relation("ReportCreatedByEmployee")
  reportRunsTriggered        ReportRun[]            @relation("ReportRunByEmployee")

  // Phase 11: Tasks
  tasksAssigned              TaskQueue[]            @relation("TaskAssignedToEmployee")
  tasksCreated               TaskQueue[]            @relation("TaskCreatedByEmployee")

  // Phase 12: Compliance
  piiAccessLogs              PIIAccessLog[]         @relation("PIIAccessByEmployee")

  // New modules
  underwriterTasks           UnderwriterTask[]      @relation("UnderwriterAssigned")
}

model LoginActivity {
  id                 String              @id @default(uuid())
  adminId            String?
  employeeId         String?
  role               String
  deviceName         String?
  deviceType         String?
  latitude           Float?
  longitude          Float?
  ipAddress          String?
  context            Json?
  loggedInAt         DateTime            @default(now())
  userUpdateRequests UserUpdateRequest[]
  admin              Admin?              @relation(fields: [adminId], references: [id])
  employee           Employee?           @relation(fields: [employeeId], references: [id])
  actionLogs         ActionLog[]
}

model ActionLog {
  id              String  @id @default(uuid())
  adminId         String?
  employeeId      String?
  loginActivityId String?

  action    String
  targetId  String?
  table     String?
  metadata  Json?
  oldData   Json?    // field-level snapshot before change
  newData   Json?    // field-level snapshot after change
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  admin         Admin?         @relation(fields: [adminId], references: [id])
  employee      Employee?      @relation(fields: [employeeId], references: [id])
  loginActivity LoginActivity? @relation(fields: [loginActivityId], references: [id])
}

// ==========================
// 👥 Users
// ==========================
model User {
  id                 String   @id @default(uuid())
  firstName          String   @default("")
  middleName         String   @default("")
  lastName           String   @default("")
  relationFirstName  String   @default("")
  relationMiddleName String   @default("")
  relationLastName   String   @default("")
  dateOfBirth        DateTime @default(now())
  maritalStatus      String?  @default("")
  email              String?  @unique
  phone              String?  @unique
  officeNumber       String? // Office contact number
  createdBy          String?
  adminId            String?
  employeeId         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  isBlocked          Boolean  @default(false)
  isDeleted          Boolean  @default(false)
  deletedAt          DateTime?
  deletedBy          String?
  isDefaulter        Boolean  @default(false)
  qualification      String?
  profession         String?
  creditScore        Int?
  proofOfIncome      String?
  regionId           String?
  photoId            String?
  genderId           String?
  relationTypeId     String?

  region       Region?       @relation(fields: [regionId], references: [id])
  relationType RelationType? @relation(fields: [relationTypeId], references: [id])
  gender       Gender?       @relation(fields: [genderId], references: [id])
  photo        File?         @relation("Photo", fields: [photoId], references: [id])
  admin        Admin?        @relation(fields: [adminId], references: [id])
  employee     Employee?     @relation(fields: [employeeId], references: [id])

  guarantorReputationScore Int? // Calculated based on the loans they guaranteed
  totalGuaranteedLoans     Int? // How many loans user has guaranteed
  successfulGuarantees     Int? // Loans where borrower paid on time
  failedGuarantees         Int? // Loans where borrower defaulted
  guarantorLoans           LoanGuarantor[]        @relation("UserAsGuarantor")
  loans                    Loan[]
  loanApplicationDrafts    LoanApplicationDraft[]
  photoIds                 PhotoID[]
  proofOfIncomeImages      File[]                 @relation("ProofOfIncomeImages")
  updateRequests           UserUpdateRequest[]
  addresses                UserAddress[]
  guarantors               UserGuarantor[] // Guarantors for this user
  grievances               GrievanceTicket[]
  kycRecord                KYCRecord?
  consentRecords           ConsentRecord[]
  nachMandates             NachMandate[]
  coBorrowerLoans          LoanCoBorrower[]  @relation("CoBorrowerUser")
}

model UserAddress {
  id                String   @id @default(uuid())
  userId            String
  addressCategoryId String
  address           String
  country           String
  stateId           String
  cityId            String
  pincode           Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  addressCategory AddressCategory @relation(fields: [addressCategoryId], references: [id])
  state           State           @relation(fields: [stateId], references: [id])
  city            City            @relation(fields: [cityId], references: [id])
}

// Guarantor model for users - stores guarantor information separately
// Note: Photo IDs are NOT stored in PhotoID table to avoid conflicts if guarantor becomes a user
model UserGuarantor {
  id         String @id @default(uuid())
  userId     String
  name       String // Full name of guarantor
  fatherName String // Father's name
  mobileNo   String // Mobile number
  address    String // Full address

  // Photo ID details stored directly (not in PhotoID table to avoid conflicts)
  photoIdType1   String? // e.g., "AADHAAR", "PAN", etc.
  photoIdNumber1 String? // ID number
  photoIdImages1 Json? // Array of image URLs/objects

  photoIdType2   String? // Second photo ID type
  photoIdNumber2 String? // Second ID number
  photoIdImages2 Json? // Array of image URLs/objects

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserUpdateRequest {
  id                    String         @id @default(uuid())
  userId                String
  changes               Json
  status                String         @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedByAdminId     String?
  updatedAt             DateTime?
  rejectedReason        String?
  loginActivityId       String?
  requestedByAdminId    String?
  requestedByEmployeeId String?
  user                  User           @relation(fields: [userId], references: [id])
  loginActivity         LoginActivity? @relation(fields: [loginActivityId], references: [id])
  requestedByAdmin      Admin?         @relation("RequestedByAdmin", fields: [requestedByAdminId], references: [id])
  requestedByEmployee   Employee?      @relation("RequestedByEmployee", fields: [requestedByEmployeeId], references: [id])
}

model RelationType {
  id        String   @id @default(uuid())
  name      String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model AddressCategory {
  id            String        @id @default(uuid())
  name          String        @unique
  value         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  userAddresses UserAddress[]
}

model Gender {
  id        String   @id @default(uuid())
  name      String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  regionId  String
  address   String?
  pincode   Int?
  latitude  Float?
  longitude Float?
  phone     String?
  email     String?
  isDeleted Boolean? @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  region          Region            @relation(fields: [regionId], references: [id])
  loans           Loan[]
  employees       Employee[]
  showrooms       Showroom[]
  grievances      GrievanceTicket[]
  collectionCases CollectionCase[]
  dayEndClosings  DayEndClosing[]

  @@unique([name, regionId]) // Prevent duplicate branch names in the same region
}

model Showroom {
  id        String   @id @default(uuid())
  name      String
  branchId  String
  address   String?
  pincode   Int?
  latitude  Float?
  longitude Float?
  phone     String?
  email     String?
  isDeleted Boolean? @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])
  loans  Loan[]

  @@unique([name, branchId]) // Prevent duplicate showroom names in the same branch
}

model PhotoID {
  id            String @id @default(uuid())
  userId        String
  photoIdTypeId String
  photoIdNumber String @unique

  user        User        @relation(fields: [userId], references: [id])
  photoIdType PhotoIdType @relation(fields: [photoIdTypeId], references: [id])
  images      File[]      @relation("PhotoIDImages")
}

model PhotoIdType {
  id           String    @id @default(uuid())
  name         String    @unique
  description  String
  minLength    Int
  maxLength    Int
  numberTypeEg String
  validation   String?
  photoIds     PhotoID[]
}

// ==========================
// 💳 Loan & Payments
// ==========================

model LoanType {
  id          String  @id @default(uuid())
  name        String  @unique
  label       String
  description String?
  rules       Json?

  loans        Loan[]
  ruleVersions LoanTypeRuleVersion[]
}

model LoanGuarantor {
  id          String @id @default(uuid())
  loanId      String
  guarantorId String

  performanceScore Float? // Optional: Custom logic
  isFlagged        Boolean? @default(false) // Whether to warn this guarantor
  notes            String? // For remarks like "Defaulted twice", etc.

  loan      Loan @relation(fields: [loanId], references: [id])
  guarantor User @relation("UserAsGuarantor", fields: [guarantorId], references: [id])

  createdAt DateTime @default(now())
}

enum FileStatus {
  INITIATED // File created, awaiting further action
  IN_PROGRESS // Processing underway (verification, evaluation)
  PENDING_APPROVAL // Waiting for final approval
  APPROVED // Approved but not yet disbursed
  DISBURSED // Loan amount given to the user
  ACTIVE // Loan is live, repayment ongoing
  OVERDUE // Payment due is late
  DEFAULTED // Repeated missed payments / declared default
  SEIZED_INITIATED // Product/assets seized due to non-payment
  SEIZED // Product/assets seized due to non-payment
  CLOSED // Loan fully repaid and file closed
  REJECTED // Application rejected before approval
  CANCELLED // File manually cancelled before any disbursal
  LEGAL_ACTION // Under legal processing
  WRITTEN_OFF // Loan marked as bad debt/loss
  UNDER_COLLECTION // Sent to recovery team or agents
  FORECLOSURE_IN_PROGRESS // Under foreclosure process
  FORECLOSED // Foreclosure completed
}

enum GrievanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum GrievancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum GrievanceSource {
  BRANCH
  CALL_CENTER
  EMAIL
  WEB
  APP
  OTHER
}

enum CollectionCaseStatus {
  OPEN
  IN_PROGRESS
  PROMISE_TO_PAY
  BROKEN_PROMISE
  RESOLVED
  CLOSED
}

enum CollectionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CollectionActionType {
  CALL
  VISIT
  NOTICE
  WHATSAPP
  SMS
  EMAIL
  PROMISE_TO_PAY
  SETTLEMENT_DISCUSSION
  FOLLOW_UP
  OTHER
}

model Loan {
  id            String    @id @default(uuid())
  fileNo        String    @unique
  loanTypeId    String
  loanType      LoanType  @relation(fields: [loanTypeId], references: [id])
  disbursedDate DateTime?
  agreementDate DateTime?

  // productAmount        Float? // REMOVED: No longer collecting product amount
  // downPayment          Float? // REMOVED: No longer collecting down payment
  principalLoanAmount  Float
  interestAmount       Float
  totalAmount          Float
  totalPaidPrincipal   Float      @default(0)
  totalPaidInterest    Float      @default(0)
  totalPaidFine        Float      @default(0)
  totalPaidAmount      Float      @default(0)
  monthlyPayableAmount Float
  pendingAmount        Float
  rtoCharges           Float?
  processingCharges    Float?
  otherCharges         Float?
  // ourPaymentType       String? // REMOVED: Payment setup section removed from loan creation
  interestRate         Float
  interestType         String?
  penaltyPercentage    Float
  tenureMonths         Int
  startDate            DateTime
  endDate              DateTime
  dueDay               Int        @default(5)
  paymentFrequency     String?    @default("MONTHLY")
  fileStatus           FileStatus @default(INITIATED)
  isClosed             Boolean    @default(false)
  isDeleted            Boolean    @default(false)
  deletedAt            DateTime?
  deletedBy            String?
  isDefaulted          Boolean    @default(false)
  totalDelayDays       Int        @default(0)
  defaultReason        String?
  insuranceAmount      Float?
  insuranceDate        DateTime?
  insuranceValidTill   DateTime?
  insuranceAlert       Boolean    @default(false)
  insuranceNumber      String?
  insuranceCompany     String?
  loanInvoiceDoc       File[]     @relation("loanInvoiceDoc")
  insuranceDoc         File[]     @relation("insuranceDoc")
  registrationDoc      File[]     @relation("registrationDoc")
  comment              String?
  isForeclosed         Boolean    @default(false)
  foreclosedAt         DateTime?
  approvalComment      String?
  approvedAt           DateTime?
  approvedByAdminId    String?
  approvedByEmployeeId String?
  createdBy            String?
  adminId              String?
  employeeId           String?
  userId               String
  branchId             String?
  showroomId           String?

  branch                 Branch?                 @relation(fields: [branchId], references: [id])
  showroom               Showroom?               @relation(fields: [showroomId], references: [id])
  admin                  Admin?                  @relation(fields: [adminId], references: [id])
  employee               Employee?               @relation(fields: [employeeId], references: [id])
  approvedByAdmin        Admin?                  @relation("LoanApprovedByAdmin", fields: [approvedByAdminId], references: [id])
  approvedByEmployee     Employee?               @relation("LoanApprovedByEmployee", fields: [approvedByEmployeeId], references: [id])
  user                   User                    @relation(fields: [userId], references: [id])
  emi                    EMI[]
  payments               Payment[]
  paymentOrders          PaymentOrder[]
  seizedHistories        SeizedHistory[]
  guarantors             LoanGuarantor[]
  twoWheelerLoan         TwoWheelerLoan?
  agriLoan               AgricultureLoan?
  msmeLoan               MSMELoan?
  forecloseRequests      ForecloseRequest[]
  pendingUPITransactions PendingUPITransaction[]
  editDrafts             LoanApplicationDraft[]
  grievances             GrievanceTicket[]
  publicAccessSessions   PublicAccessSession[]
  collectionCases        CollectionCase[]
  kfsDeliveries          KFSDelivery[]
  restructuringRequests  RestructuringRequest[]
  waiverRequests         WaiverRequest[]
  collateralRecords      CollateralRecord[]
  promisesToPay          PromiseToPay[]
  legalActions           LegalAction[]
  partnerPayouts         PartnerPayout[]
  nachMandates           NachMandate[]
  bounceEvents           BounceEvent[]
  coBorrowers            LoanCoBorrower[]
  disbursalChecklist     DisbursalChecklist?
  disbursalHolds         DisbursalHold[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId]) // hot: list loans per user
  @@index([fileStatus]) // hot: filter by status (pending approval, overdue, etc.)
  @@index([branchId, fileStatus]) // hot: branch-scoped dashboard queries
  @@index([employeeId, fileStatus]) // hot: employee-scoped dashboard queries
  @@index([disbursedDate]) // hot: disbursement trend queries
}

model AppConfig {
  id                  String   @id @default(uuid())
  key                 String   @unique
  category            String
  label               String
  description         String?
  value               Json
  isPublic            Boolean  @default(false)
  updatedByAdminId    String?
  updatedByEmployeeId String?
  createdAt           DateTime @default(now())
