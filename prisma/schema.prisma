model EMI {
  id          String   @id @default(uuid())
  loanId      String
  paymentFor  DateTime
  paymentDate DateTime @default(now())

  emiPayAmount    Decimal @default(0)
  principalAmt    Decimal @default(0)
  interestAmt     Decimal @default(0)
  amountPaidSoFar Decimal @default(0)
  finePaid        Decimal @default(0)
  totalPaid       Decimal @default(0)
  principalPaid   Decimal @default(0)
  interestPaid    Decimal @default(0)

  status String @default("UNPAID")

  isForeclosure        Boolean   @default(false)
  isDelayed            Boolean   @default(false)
  delayDays            Int?
  fineAmount           Float?
  verified             Boolean   @default(false)
  verifiedAt           DateTime?
  verifiedByAdminId    String?
  verifiedByEmployeeId String?

  loan      Loan     @relation(fields: [loanId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  payments Payment[] // one-to-many: all payments linked to this EMI

  @@index([loanId, status]) // hot: all UNPAID/PARTIAL EMIs per loan
  @@index([loanId, paymentFor]) // hot: fine-refresh ORDER BY paymentFor queries
  @@index([status, paymentFor]) // hot: due-this-week / upcoming EMI dashboard queries
}

model Payment {
  id                   String       @id @default(uuid())
  loanId               String
  emiId                String?
  amount               Decimal?     @default(0)
  paymentDate          DateTime     @default(now())
  paymentMode          PaymentMode?
  transactionId        String?
  status               String       @default("PENDING") // PENDING, PAID, UNVERIFIED
  isForeclosure        Boolean      @default(false)
  verified             Boolean      @default(false)
  verifiedAt           DateTime?
  verifiedByAdminId    String?
  verifiedByEmployeeId String?
  fineDiscount         Decimal?     @default(0) // Discount applied on fine/penal charges
  loanPendingBefore    Decimal? // Loan pending amount before this payment
  loanPendingAfter     Decimal? // Loan pending amount after this payment
  metadata             Json?
  adminId              String?
  employeeId           String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @default(now()) @updatedAt
  emi                  EMI?         @relation(fields: [emiId], references: [id])
  verifiedByAdmin      Admin?       @relation("VerifiedByAdmin", fields: [verifiedByAdminId], references: [id])
  verifiedByEmployee   Employee?    @relation("VerifiedByEmployee", fields: [verifiedByEmployeeId], references: [id])
  admin                Admin?       @relation(fields: [adminId], references: [id])
  employee             Employee?    @relation(fields: [employeeId], references: [id])
  loan                 Loan         @relation(fields: [loanId], references: [id])
  reversalRequests     ReversalRequest[]

  @@index([loanId, status]) // hot: unverified/pending payments per loan
  @@index([paymentDate, status]) // hot: dashboard monthly collection aggregate
  @@index([emiId]) // hot: payments linked to a specific EMI
}

model ForecloseRequest {
  id                    String       @id @default(uuid())
  loanId                String
  requestedAmount       Decimal
  calculatedAmount      Decimal
  paymentMode           PaymentMode?
  transactionId         String?
  paymentDate           DateTime
  status                String       @default("PENDING") // PENDING, APPROVED, REJECTED
  approvalComment       String?
  approvedAt            DateTime?
  approvedByAdminId     String?
  approvedByEmployeeId  String?
  requestedByAdminId    String?
  requestedByEmployeeId String?
