  @@index([loanId, status])
  @@index([expiresAt])
}

model GrievanceTicket {
  id                   String            @id @default(uuid())
  ticketNumber         String            @unique
  category             String
  subject              String
  description          String
  status               GrievanceStatus   @default(OPEN)
  priority             GrievancePriority @default(MEDIUM)
  source               GrievanceSource   @default(BRANCH)
  metadata             Json?
  dueAt                DateTime?
  firstResponseAt      DateTime?
  resolvedAt           DateTime?
  resolutionSummary    String?
  resolutionMetadata   Json?
  userId               String?
  loanId               String?
  branchId             String?
  assignedToEmployeeId String?
  createdByAdminId     String?
  createdByEmployeeId  String?
  assignedByAdminId    String?
  assignedByEmployeeId String?
  resolvedByAdminId    String?
  resolvedByEmployeeId String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  user               User?              @relation(fields: [userId], references: [id])
  loan               Loan?              @relation(fields: [loanId], references: [id])
  branch             Branch?            @relation(fields: [branchId], references: [id])
  assignedToEmployee Employee?          @relation("GrievanceAssignedToEmployee", fields: [assignedToEmployeeId], references: [id])
  createdByAdmin     Admin?             @relation("GrievanceCreatedByAdmin", fields: [createdByAdminId], references: [id])
  createdByEmployee  Employee?          @relation("GrievanceCreatedByEmployee", fields: [createdByEmployeeId], references: [id])
  assignedByAdmin    Admin?             @relation("GrievanceAssignedByAdmin", fields: [assignedByAdminId], references: [id])
  assignedByEmployee Employee?          @relation("GrievanceAssignedByEmployee", fields: [assignedByEmployeeId], references: [id])
  resolvedByAdmin    Admin?             @relation("GrievanceResolvedByAdmin", fields: [resolvedByAdminId], references: [id])
  resolvedByEmployee Employee?          @relation("GrievanceResolvedByEmployee", fields: [resolvedByEmployeeId], references: [id])
