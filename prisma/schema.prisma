  assignedByEmployee Employee?          @relation("CollectionCaseAssignedByEmployee", fields: [assignedByEmployeeId], references: [id])
  closedByAdmin      Admin?             @relation("CollectionCaseClosedByAdmin", fields: [closedByAdminId], references: [id])
  closedByEmployee   Employee?          @relation("CollectionCaseClosedByEmployee", fields: [closedByEmployeeId], references: [id])
