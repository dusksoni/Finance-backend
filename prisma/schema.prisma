// ==========================
// ✅ PHASE 2: Approval Matrix + Maker-Checker
// ==========================

enum ApprovalEntityType {
  LOAN
  PAYMENT
  WAIVER
  FORECLOSURE
  SETTLEMENT
  WRITE_OFF
  RESTRUCTURING
  COLLATERAL_RELEASE
  PARTNER_PAYOUT
}

enum ApprovalRequestStatus {
  PENDING
  PARTIALLY_APPROVED
  APPROVED
  REJECTED
  EXPIRED
}

enum ApprovalVoteDecision {
  APPROVED
  REJECTED
}

model ApprovalMatrix {
  id              String             @id @default(uuid())
  entityType      ApprovalEntityType
  name            String
  description     String?
  minAmount       Decimal            @default(0)
  maxAmount       Decimal?           // null = no upper bound
  requiredCount   Int                @default(1)
  requiredRoleIds String[]           // roles whose members can approve
  autoApprove     Boolean            @default(false)
  isActive        Boolean            @default(true)
  priority        Int                @default(0) // higher = checked first
  createdByAdminId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  createdByAdmin Admin? @relation(fields: [createdByAdminId], references: [id])
  requests       ApprovalRequest[]

  @@index([entityType, isActive])
}

model ApprovalRequest {
  id             String                 @id @default(uuid())
  matrixId       String?
  entityType     ApprovalEntityType
  entityId       String
  requestedAmount Decimal?
  status         ApprovalRequestStatus  @default(PENDING)
  requiredCount  Int                    @default(1)
  approvedCount  Int                    @default(0)
  rejectedCount  Int                    @default(0)
  expiresAt      DateTime?
  rejectionReason String?
  metadata       Json?
  requestedByAdminId    String?
  requestedByEmployeeId String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  matrix              ApprovalMatrix? @relation(fields: [matrixId], references: [id])
  requestedByAdmin    Admin?          @relation("ApprovalRequestedByAdmin", fields: [requestedByAdminId], references: [id])
  requestedByEmployee Employee?       @relation("ApprovalRequestedByEmployee", fields: [requestedByEmployeeId], references: [id])
  votes               ApprovalVote[]

  @@index([entityType, entityId])
  @@index([status])
}

model ApprovalVote {
  id                String               @id @default(uuid())
  requestId         String
  decision          ApprovalVoteDecision
  reason            String?
  votedByAdminId    String?
  votedByEmployeeId String?
  createdAt         DateTime             @default(now())

  request         ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  votedByAdmin    Admin?          @relation("ApprovalVoteByAdmin", fields: [votedByAdminId], references: [id])
  votedByEmployee Employee?       @relation("ApprovalVoteByEmployee", fields: [votedByEmployeeId], references: [id])

  @@index([requestId])
}

model OverrideLog {
  id                  String             @id @default(uuid())
  entityType          ApprovalEntityType
  entityId            String
  action              String
  reason              String
  supervisorAdminId   String?
  overriddenByAdminId    String?
  overriddenByEmployeeId String?
  metadata            Json?
  createdAt           DateTime           @default(now())

  overriddenByAdmin    Admin?    @relation("OverrideByAdmin", fields: [overriddenByAdminId], references: [id])
  overriddenByEmployee Employee? @relation("OverrideByEmployee", fields: [overriddenByEmployeeId], references: [id])
  supervisorAdmin      Admin?    @relation("OverrideSupervisor", fields: [supervisorAdminId], references: [id])

  @@index([entityType, entityId])
}

// ==========================
// 🪪 PHASE 3: KYC Status Machine
// ==========================

enum KYCStatus {
  DRAFT
  PARTIALLY_VERIFIED
  FULLY_VERIFIED
  EXPIRED
  RE_KYC_DUE
  REJECTED
}

enum KYCRiskFlagType {
  PEP                  // Politically Exposed Person
  DUPLICATE_MOBILE
  DUPLICATE_PAN
  DUPLICATE_AADHAAR
  ADDRESS_MISMATCH
  BUREAU_MISMATCH
  BLACKLIST_HIT
  WATCHLIST_MATCH
  OTHER
}

model KYCRecord {
  id                  String    @id @default(uuid())
  userId              String    @unique
  status              KYCStatus @default(DRAFT)
  verificationMethod  String?   // PHYSICAL, CKYC, DIGILOCKER, VCIP, OTP_ASSISTED
  verifiedByAdminId    String?
  verifiedByEmployeeId String?
  verifiedAt          DateTime?
  expiresAt           DateTime?
  nextReviewDue       DateTime?
  rejectionReason     String?
  reviewNotes         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedByAdmin    Admin?    @relation("KYCVerifiedByAdmin", fields: [verifiedByAdminId], references: [id])
  verifiedByEmployee Employee? @relation("KYCVerifiedByEmployee", fields: [verifiedByEmployeeId], references: [id])
  documents         KYCDocument[]
  riskFlags         KYCRiskFlag[]

  @@index([status])
}

model KYCDocument {
  id              String    @id @default(uuid())
  kycRecordId     String
  documentType    String    // AADHAAR, PAN, VOTER_ID, PASSPORT, etc.
  documentNumber  String?
  fileId          String?
  verificationStatus String @default("PENDING") // PENDING, VERIFIED, REJECTED
  verifiedByAdminId    String?
  verifiedByEmployeeId String?
  verifiedAt      DateTime?
  expiresAt       DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  kycRecord          KYCRecord @relation(fields: [kycRecordId], references: [id], onDelete: Cascade)
  verifiedByAdmin    Admin?    @relation("KYCDocVerifiedByAdmin", fields: [verifiedByAdminId], references: [id])
  verifiedByEmployee Employee? @relation("KYCDocVerifiedByEmployee", fields: [verifiedByEmployeeId], references: [id])

  @@index([kycRecordId])
}

model KYCRiskFlag {
  id           String          @id @default(uuid())
  kycRecordId  String
  flagType     KYCRiskFlagType
  description  String?
  isResolved   Boolean         @default(false)
  resolvedAt   DateTime?
  resolvedByAdminId    String?
  resolvedByEmployeeId String?
  resolutionNote String?
  metadata     Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  kycRecord          KYCRecord @relation(fields: [kycRecordId], references: [id], onDelete: Cascade)
  resolvedByAdmin    Admin?    @relation("KYCFlagResolvedByAdmin", fields: [resolvedByAdminId], references: [id])
  resolvedByEmployee Employee? @relation("KYCFlagResolvedByEmployee", fields: [resolvedByEmployeeId], references: [id])

  @@index([kycRecordId, isResolved])
  @@index([flagType, isResolved])
}

model BlacklistEntry {
  id          String   @id @default(uuid())
  valueType   String   // PAN, AADHAAR, MOBILE, EMAIL
  value       String
  reason      String
  isActive    Boolean  @default(true)
  addedByAdminId String?
  removedByAdminId String?
  removedAt   DateTime?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  addedByAdmin   Admin? @relation("BlacklistAddedBy", fields: [addedByAdminId], references: [id])
  removedByAdmin Admin? @relation("BlacklistRemovedBy", fields: [removedByAdminId], references: [id])

  @@unique([valueType, value])
  @@index([valueType, isActive])
}

// ==========================
// 📋 PHASE 4: Consent Management + KFS Delivery
// ==========================

enum ConsentType {
  DATA_PROCESSING
  BUREAU_PULL
  ACCOUNT_ACCESS
  COMMUNICATION
  ESIGN
  LOAN_TERMS
  KFS_ACCEPTANCE
  NACH_MANDATE
}

model ConsentTemplate {
  id          String   @id @default(uuid())
  consentType ConsentType
  version     String
  language    String   @default("en")
  title       String
  body        String   @db.Text
  isActive    Boolean  @default(true)
  createdByAdminId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdByAdmin Admin?          @relation(fields: [createdByAdminId], references: [id])
  records        ConsentRecord[]

  @@unique([consentType, version, language])
  @@index([consentType, isActive])
}

model ConsentRecord {
  id              String      @id @default(uuid())
  userId          String
  loanId          String?
  consentType     ConsentType
  templateId      String?
  version         String?
  channel         String?     // WEB, APP, BRANCH, API
  ipAddress       String?
  deviceInfo      String?
  consentedAt     DateTime    @default(now())
  expiresAt       DateTime?
  isWithdrawn     Boolean     @default(false)
  withdrawnAt     DateTime?
  withdrawalReason String?
  metadata        Json?

  user     User            @relation(fields: [userId], references: [id])
  template ConsentTemplate? @relation(fields: [templateId], references: [id])

  @@index([userId, consentType])
  @@index([loanId, consentType])
}

model KFSDelivery {
  id             String    @id @default(uuid())
  loanId         String
  version        String
  templateId     String?
  deliveredAt    DateTime  @default(now())
  deliveryChannel String?  // WEB, APP, EMAIL, BRANCH
  acceptedAt     DateTime?
  ipAddress      String?
  deviceInfo     String?
  fileId         String?   // PDF of the KFS
  metadata       Json?

  loan Loan @relation(fields: [loanId], references: [id])

  @@index([loanId])
}

// ==========================
// 🔄 PHASE 5: Restructuring / Rescheduling / Settlement / Waiver
// ==========================

enum RestructuringType {
  RESCHEDULE
  TOP_UP
  SETTLEMENT
  WRITE_OFF
  MORATORIUM
}

enum RestructuringStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  APPLIED
  CANCELLED
}

model RestructuringRequest {
  id                    String              @id @default(uuid())
  loanId                String
  type                  RestructuringType
  status                RestructuringStatus @default(DRAFT)
  reason                String
  boardApprovalRequired Boolean             @default(false)
  boardApprovalNote     String?

  // Waiver components (if any)
  interestWaived        Decimal             @default(0)
  fineWaived            Decimal             @default(0)
  principalWaived       Decimal             @default(0)

  // New schedule parameters (for RESCHEDULE / MORATORIUM)
  newTenureMonths       Int?
  newInterestRate       Float?
  newStartDate          DateTime?
  newEmiAmount          Decimal?
  moratoriumMonths      Int?

  // Settlement
  settlementAmount      Decimal?
  settlementDate        DateTime?

  // Snapshot of old schedule before change
  oldScheduleSnapshot   Json?
  // Generated new schedule (stored before activation)
  newScheduleSnapshot   Json?

  approvalComment       String?
  rejectionReason       String?
  appliedAt             DateTime?

  requestedByAdminId    String?
  requestedByEmployeeId String?
  approvedByAdminId     String?
  approvedByEmployeeId  String?
  metadata              Json?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  loan                  Loan      @relation(fields: [loanId], references: [id])
  requestedByAdmin      Admin?    @relation("RestructureRequestedByAdmin", fields: [requestedByAdminId], references: [id])
  requestedByEmployee   Employee? @relation("RestructureRequestedByEmployee", fields: [requestedByEmployeeId], references: [id])
  approvedByAdmin       Admin?    @relation("RestructureApprovedByAdmin", fields: [approvedByAdminId], references: [id])
  approvedByEmployee    Employee? @relation("RestructureApprovedByEmployee", fields: [approvedByEmployeeId], references: [id])
  waiverRequests        WaiverRequest[]

  @@index([loanId, status])
}

enum WaiverType {
  INTEREST
  FINE
  PRINCIPAL
  PROCESSING_FEE
  OTHER
}

enum WaiverStatus {
  PENDING
  APPROVED
  REJECTED
}

model WaiverRequest {
  id                    String        @id @default(uuid())
  loanId                String
  restructuringId       String?
  waiverType            WaiverType
  requestedAmount       Decimal
  approvedAmount        Decimal?
  reason                String
  status                WaiverStatus  @default(PENDING)
  policyLimitCheck      Boolean       @default(false)
  rejectionReason       String?
  approvalComment       String?
  requestedByAdminId    String?
  requestedByEmployeeId String?
  approvedByAdminId     String?
  approvedByEmployeeId  String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  loan                Loan                  @relation(fields: [loanId], references: [id])
  restructuring       RestructuringRequest? @relation(fields: [restructuringId], references: [id])
  requestedByAdmin    Admin?                @relation("WaiverRequestedByAdmin", fields: [requestedByAdminId], references: [id])
  requestedByEmployee Employee?             @relation("WaiverRequestedByEmployee", fields: [requestedByEmployeeId], references: [id])
  approvedByAdmin     Admin?                @relation("WaiverApprovedByAdmin", fields: [approvedByAdminId], references: [id])
  approvedByEmployee  Employee?             @relation("WaiverApprovedByEmployee", fields: [approvedByEmployeeId], references: [id])

  @@index([loanId, status])
}

// ==========================
// 💰 PHASE 6: Reconciliation + Day-End + Suspense + Reversal
// ==========================

enum DayEndStatus {
  OPEN
  SUBMITTED
  APPROVED
  REJECTED
}

model DayEndClosing {
  id               String       @id @default(uuid())
  branchId         String
  date             DateTime     @db.Date
  openingCash      Decimal      @default(0)
  expectedCash     Decimal      @default(0)  // sum of cash payments logged
  declaredCash     Decimal      @default(0)  // what branch declares
  variance         Decimal      @default(0)  // declaredCash - expectedCash
  totalCollections Decimal      @default(0)
  totalOnline      Decimal      @default(0)
  notes            String?
  status           DayEndStatus @default(OPEN)
  submittedAt      DateTime?
  approvedAt       DateTime?
  submittedByAdminId    String?
  submittedByEmployeeId String?
  approvedByAdminId     String?
  rejectionReason  String?
  metadata         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  branch              Branch    @relation(fields: [branchId], references: [id])
  submittedByAdmin    Admin?    @relation("DayEndSubmittedByAdmin", fields: [submittedByAdminId], references: [id])
  submittedByEmployee Employee? @relation("DayEndSubmittedByEmployee", fields: [submittedByEmployeeId], references: [id])
  approvedByAdmin     Admin?    @relation("DayEndApprovedByAdmin", fields: [approvedByAdminId], references: [id])

  @@unique([branchId, date])
  @@index([date, status])
}

model BankReconciliation {
  id                String   @id @default(uuid())
  branchId          String?
  statementDate     DateTime @db.Date
  bankAccountNumber String?
  bankName          String?
  statementAmount   Decimal  // Amount as per bank statement
  systemAmount      Decimal  // Amount as per system records
  variance          Decimal  @default(0)
  isReconciled      Boolean  @default(false)
  reconciledAt      DateTime?
  notes             String?
  reconciledByAdminId    String?
  reconciledByEmployeeId String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  reconciledByAdmin    Admin?    @relation("BankReconByAdmin", fields: [reconciledByAdminId], references: [id])
  reconciledByEmployee Employee? @relation("BankReconByEmployee", fields: [reconciledByEmployeeId], references: [id])

  @@index([statementDate, isReconciled])
}

enum SuspenseStatus {
  UNRESOLVED
  RESOLVED
  REFUNDED
}

model SuspenseAccount {
  id            String         @id @default(uuid())
  amount        Decimal
  source        String         // BANK_TRANSFER, UPI, CASH, CHEQUE, OTHER
  receivedAt    DateTime
  referenceNo   String?
  senderInfo    String?
  notes         String?
  status        SuspenseStatus @default(UNRESOLVED)
  resolvedLoanId String?
  resolvedAt    DateTime?
  resolvedByAdminId    String?
  resolvedByEmployeeId String?
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  resolvedByAdmin    Admin?    @relation("SuspenseResolvedByAdmin", fields: [resolvedByAdminId], references: [id])
  resolvedByEmployee Employee? @relation("SuspenseResolvedByEmployee", fields: [resolvedByEmployeeId], references: [id])

  @@index([status])
}

enum ReversalStatus {
  PENDING
  APPROVED
  PROCESSED
  REJECTED
}

model ReversalRequest {
  id                String        @id @default(uuid())
  paymentId         String
  reason            String
  requestedAmount   Decimal
  approvedAmount    Decimal?
  status            ReversalStatus @default(PENDING)
  rejectionReason   String?
  processedAt       DateTime?
  requestedByAdminId    String?
  requestedByEmployeeId String?
  approvedByAdminId     String?
  approvedByEmployeeId  String?
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  payment             Payment   @relation(fields: [paymentId], references: [id])
  requestedByAdmin    Admin?    @relation("ReversalRequestedByAdmin", fields: [requestedByAdminId], references: [id])
  requestedByEmployee Employee? @relation("ReversalRequestedByEmployee", fields: [requestedByEmployeeId], references: [id])
  approvedByAdmin     Admin?    @relation("ReversalApprovedByAdmin", fields: [approvedByAdminId], references: [id])
  approvedByEmployee  Employee? @relation("ReversalApprovedByEmployee", fields: [approvedByEmployeeId], references: [id])

  @@index([paymentId])
  @@index([status])
}

// ==========================
// 📊 PHASE 7: Collections Enhancements
// ==========================

model CollectionBucketConfig {
  id                    String   @id @default(uuid())
  name                  String   @unique  // e.g. "BUCKET_0", "BUCKET_1_30"
  label                 String
  minDpd                Int
  maxDpd                Int?     // null = open-ended (90+)
  priority              CollectionPriority @default(MEDIUM)
  contactMethodOrder    String[] // ["CALL","VISIT","WHATSAPP"]
  escalationSlaHours    Int      @default(72)
  maxAttemptsBeforeEscalate Int  @default(3)
  autoEscalate          Boolean  @default(true)
  legalEligible         Boolean  @default(false)
  settlementEligible    Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([minDpd])
}

model PromiseToPay {
  id              String   @id @default(uuid())
  caseId          String
  loanId          String
  promiseDate     DateTime
  promiseAmount   Decimal
  isFulfilled     Boolean  @default(false)
  isBroken        Boolean  @default(false)
  fulfilledAt     DateTime?
  brokenAt        DateTime?
  followUpDate    DateTime?
  notes           String?
  createdByAdminId    String?
  createdByEmployeeId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  collectionCase  CollectionCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  loan            Loan           @relation(fields: [loanId], references: [id])
  createdByAdmin    Admin?    @relation("PTPCreatedByAdmin", fields: [createdByAdminId], references: [id])
  createdByEmployee Employee? @relation("PTPCreatedByEmployee", fields: [createdByEmployeeId], references: [id])

  @@index([caseId])
  @@index([promiseDate, isFulfilled])
}

enum LegalStage {
  NONE
  NOTICE_SENT
  COURT_FILED
  DECREE_OBTAINED
  EXECUTION_PROCEEDING
  SETTLED_OUT_OF_COURT
  WITHDRAWN
}

model LegalAction {
  id                  String     @id @default(uuid())
  loanId              String
  caseId              String?
  stage               LegalStage @default(NONE)
  noticeDate          DateTime?
  filingDate          DateTime?
  caseNumber          String?
  court               String?
  decreeDate          DateTime?
  decreeAmount        Decimal?
  nextHearingDate     DateTime?
  notes               String?
  lawyerName          String?
  lawyerContact       String?
  fileId              String?    // Legal notice / court docs
  createdByAdminId    String?
  createdByEmployeeId String?
  updatedByAdminId    String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  loan              Loan           @relation(fields: [loanId], references: [id])
  collectionCase    CollectionCase? @relation(fields: [caseId], references: [id])
  createdByAdmin    Admin?    @relation("LegalActionCreatedByAdmin", fields: [createdByAdminId], references: [id])
  createdByEmployee Employee? @relation("LegalActionCreatedByEmployee", fields: [createdByEmployeeId], references: [id])

  @@index([loanId, stage])
}

// ==========================
// 🏦 PHASE 8: Collateral Lifecycle
// ==========================

enum CollateralType {
  VEHICLE
  PROPERTY
  EQUIPMENT
  GOLD
  INVENTORY
  OTHER
}

enum CollateralStatus {
  ACTIVE
  UNDER_LIEN
  SEIZED
  RELEASED
  SOLD
}

model CollateralRecord {
  id               String          @id @default(uuid())
  loanId           String
  collateralType   CollateralType
  description      String
  currentValue     Decimal?
  lastValuedAt     DateTime?
  nextValuationDue DateTime?
  insuredTill      DateTime?
  insuranceCompany String?
  policyNumber     String?
  status           CollateralStatus @default(ACTIVE)
  notes            String?
  metadata         Json?
  createdByAdminId    String?
  createdByEmployeeId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  loan              Loan                  @relation(fields: [loanId], references: [id])
  createdByAdmin    Admin?    @relation("CollateralCreatedByAdmin", fields: [createdByAdminId], references: [id])
  createdByEmployee Employee? @relation("CollateralCreatedByEmployee", fields: [createdByEmployeeId], references: [id])
  valuations        CollateralValuation[]

  @@index([loanId, status])
}

model CollateralValuation {
  id             String   @id @default(uuid())
  collateralId   String
  value          Decimal
  valuedAt       DateTime
  valuer         String?
  method         String?  // PHYSICAL, DESK, MARKET
  reportFileId   String?
  notes          String?
  createdByAdminId    String?
  createdByEmployeeId String?
  createdAt      DateTime @default(now())

  collateral        CollateralRecord @relation(fields: [collateralId], references: [id], onDelete: Cascade)
  createdByAdmin    Admin?    @relation("ValuationCreatedByAdmin", fields: [createdByAdminId], references: [id])
  createdByEmployee Employee? @relation("ValuationCreatedByEmployee", fields: [createdByEmployeeId], references: [id])

  @@index([collateralId, valuedAt])
}

// ==========================
// 🤝 PHASE 9: Partner / Channel Management
// ==========================

enum PartnerType {
  DSA
  DEALER
  BROKER
  FIELD_AGENT
  COLLECTION_AGENCY
  FINTECH
  OTHER
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BLACKLISTED
}

enum CommissionTrigger {
  DISBURSEMENT
  FIRST_REPAYMENT
  FULL_REPAYMENT
}

enum CommissionType {
  PERCENTAGE
  FLAT
}

model ChannelPartner {
  id                String        @id @default(uuid())
  name              String
  partnerType       PartnerType
  status            PartnerStatus @default(ACTIVE)
  contactPerson     String?
  phone             String?
  email             String?
  address           String?
  panNumber         String?
  gstNumber         String?
  agreementStart    DateTime?
  agreementEnd      DateTime?
  kycStatus         String        @default("PENDING") // PENDING, VERIFIED, REJECTED
  eligibleBranchIds String[]
  eligibleLoanTypeIds String[]
  notes             String?
  metadata          Json?
  createdByAdminId  String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  createdByAdmin    Admin?                   @relation(fields: [createdByAdminId], references: [id])
  commissionRules   PartnerCommissionRule[]
  leads             PartnerLead[]
  payouts           PartnerPayout[]
  delinquencyMetrics ChannelDelinquencyMetric[]

  @@index([partnerType, status])
}

model PartnerCommissionRule {
  id              String            @id @default(uuid())
  partnerId       String
  loanTypeId      String?
  commissionType  CommissionType    @default(PERCENTAGE)
  commissionValue Decimal
  trigger         CommissionTrigger @default(DISBURSEMENT)
  // Clawback: if borrower repays < clawbackThresholdMonths, recover commission
  clawbackEnabled         Boolean  @default(false)
  clawbackThresholdMonths Int      @default(3)
  clawbackPercent         Decimal  @default(100)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  partner  ChannelPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, isActive])
}

enum LeadStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CONVERTED
  REJECTED
  DROPPED
}

model PartnerLead {
  id              String     @id @default(uuid())
  partnerId       String
  userId          String?    // null until user record created
  loanId          String?    // null until loan sanctioned
  status          LeadStatus @default(NEW)
  source          String?
  referenceNo     String?
  convertedAt     DateTime?
  rejectionReason String?
  notes           String?
  metadata        Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  partner ChannelPartner @relation(fields: [partnerId], references: [id])

  @@index([partnerId, status])
}

enum PayoutStatus {
  PENDING
  PAID
  CLAWBACK
  CANCELLED
}

model PartnerPayout {
  id              String       @id @default(uuid())
  partnerId       String
  loanId          String
  ruleId          String?
  triggerEvent    CommissionTrigger
  commissionAmount Decimal
  gstAmount       Decimal      @default(0)
  netAmount       Decimal
  status          PayoutStatus @default(PENDING)
  paidAt          DateTime?
  transactionRef  String?
  clawbackReason  String?
  notes           String?
  processedByAdminId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  partner           ChannelPartner @relation(fields: [partnerId], references: [id])
  loan              Loan           @relation(fields: [loanId], references: [id])
  processedByAdmin  Admin?         @relation("PayoutProcessedByAdmin", fields: [processedByAdminId], references: [id])

  @@index([partnerId, status])
  @@index([loanId])
}

model ChannelDelinquencyMetric {
  id               String   @id @default(uuid())
  partnerId        String
  asOfDate         DateTime @db.Date
  totalLoans       Int      @default(0)
  activeLoans      Int      @default(0)
  overdueLoans     Int      @default(0)
  npaLoans         Int      @default(0)
  totalDisbursed   Decimal  @default(0)
  totalOverdueAmt  Decimal  @default(0)
  par30            Decimal  @default(0) // Portfolio At Risk 30+
  par90            Decimal  @default(0)
  createdAt        DateTime @default(now())

  partner ChannelPartner @relation(fields: [partnerId], references: [id])

  @@unique([partnerId, asOfDate])
}

// ==========================
// 📈 PHASE 10: Reporting Builder
// ==========================

enum ReportFrequency {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum ReportOutputFormat {
  EXCEL
  CSV
  PDF
  JSON
}

enum ReportEntityType {
  LOANS
  PAYMENTS
  USERS
  COLLECTIONS
  EMIS
  PARTNERS
  EMPLOYEES
}

model SavedReport {
  id             String             @id @default(uuid())
  name           String
  description    String?
  entityType     ReportEntityType
  filtersJson    Json?
  columnsJson    Json?
  sortJson       Json?
  schedule       ReportFrequency    @default(NONE)
  outputFormat   ReportOutputFormat @default(EXCEL)
  lastRunAt      DateTime?
  isActive       Boolean            @default(true)
  createdByAdminId    String?
  createdByEmployeeId String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  createdByAdmin    Admin?    @relation("ReportCreatedByAdmin", fields: [createdByAdminId], references: [id])
  createdByEmployee Employee? @relation("ReportCreatedByEmployee", fields: [createdByEmployeeId], references: [id])
  runs              ReportRun[]

  @@index([entityType])
}

model ReportRun {
  id          String    @id @default(uuid())
  reportId    String
  triggeredBy String    @default("MANUAL") // MANUAL | SCHEDULED
  rowCount    Int?
  fileUrl     String?
  status      String    @default("PENDING") // PENDING, COMPLETED, FAILED
  error       String?
  triggeredByAdminId    String?
  triggeredByEmployeeId String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  report              SavedReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  triggeredByAdmin    Admin?    @relation("ReportRunByAdmin", fields: [triggeredByAdminId], references: [id])
  triggeredByEmployee Employee? @relation("ReportRunByEmployee", fields: [triggeredByEmployeeId], references: [id])

  @@index([reportId, createdAt])
}

// ==========================
// ⚙️ PHASE 11: Automation Rules + Task Queue
// ==========================

enum AutomationTriggerEvent {
  EMI_DUE
  EMI_OVERDUE
  DPD_THRESHOLD
  KYC_EXPIRY
  INSURANCE_EXPIRY
  COLLATERAL_VALUATION_DUE
  PROMISE_TO_PAY_BROKEN
  COLLECTION_ESCALATION
  LOAN_APPROVED
  LOAN_DISBURSED
  PAYMENT_RECEIVED
}

enum AutomationAction {
  CREATE_TASK
  FLAG_COLLECTION_CASE
  ESCALATE_CASE
  LOG_ALERT
  SEND_NOTIFICATION
}

model AutomationRule {
  id             String                  @id @default(uuid())
  name           String
  description    String?
  triggerEvent   AutomationTriggerEvent
  conditionJson  Json?                   // e.g. { "dpdGte": 30 }
  action         AutomationAction
  actionParamsJson Json?                 // e.g. { "taskType": "FOLLOW_UP", "priority": "HIGH" }
  delayMinutes   Int                     @default(0)
  isActive       Boolean                 @default(true)
  createdByAdminId String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  createdByAdmin Admin? @relation(fields: [createdByAdminId], references: [id])

  @@index([triggerEvent, isActive])
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  ESCALATED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model TaskQueue {
  id               String       @id @default(uuid())
  taskType         String       // FOLLOW_UP, KYC_REVIEW, INSURANCE_RENEWAL, VALUATION, LEGAL_NOTICE, OTHER
  entityType       String?      // LOAN, USER, COLLATERAL, etc.
  entityId         String?
  title            String
  description      String?
  status           TaskStatus   @default(OPEN)
  priority         TaskPriority @default(MEDIUM)
  dueAt            DateTime?
  assignedToEmployeeId String?
  assignedToAdminId    String?
  automationRuleId String?
  completedAt      DateTime?
  createdByAdminId    String?
  createdByEmployeeId String?
  metadata         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  assignedToEmployee Employee? @relation("TaskAssignedToEmployee", fields: [assignedToEmployeeId], references: [id])
  assignedToAdmin    Admin?    @relation("TaskAssignedToAdmin", fields: [assignedToAdminId], references: [id])
  createdByAdmin     Admin?    @relation("TaskCreatedByAdmin", fields: [createdByAdminId], references: [id])
  createdByEmployee  Employee? @relation("TaskCreatedByEmployee", fields: [createdByEmployeeId], references: [id])

  @@index([status, priority])
  @@index([entityType, entityId])
  @@index([assignedToEmployeeId, status])
  @@index([dueAt, status])
}

model NotificationLog {
  id            String   @id @default(uuid())
  templateKey   String?
  targetType    String   // LOAN, USER, EMPLOYEE, ADMIN
  targetId      String
  triggerEvent  String?
  channel       String   @default("IN_APP") // IN_APP, SMS, EMAIL, WHATSAPP
  status        String   @default("PENDING") // PENDING, SENT, FAILED
  contentRendered String? @db.Text
  error         String?
  sentAt        DateTime?
  createdAt     DateTime @default(now())

  @@index([targetType, targetId])
  @@index([status, createdAt])
}

// ==========================
// 🗂️ PHASE 12: Data Retention + Legal Hold + PII Access Log
// ==========================

enum LegalHoldEntityType {
  USER
  LOAN
  PAYMENT
  COLLECTION_CASE
  GRIEVANCE
}

model LegalHold {
  id          String              @id @default(uuid())
  entityType  LegalHoldEntityType
  entityId    String
  reason      String
  heldByAdminId String?
  releasedByAdminId String?
  releasedAt  DateTime?
  releaseNote String?
  metadata    Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  heldByAdmin     Admin? @relation("LegalHoldHeldBy", fields: [heldByAdminId], references: [id])
  releasedByAdmin Admin? @relation("LegalHoldReleasedBy", fields: [releasedByAdminId], references: [id])

  @@unique([entityType, entityId])
  @@index([entityType, entityId])
}

model PIIAccessLog {
  id          String   @id @default(uuid())
  targetUserId String
  fieldName   String   // AADHAAR, PAN, MOBILE, DOB, BANK_ACCOUNT
  accessedByAdminId    String?
  accessedByEmployeeId String?
  purpose     String?  // KYC_VERIFICATION, LOAN_PROCESSING, AUDIT, etc.
  ipAddress   String?
  createdAt   DateTime @default(now())

  accessedByAdmin    Admin?    @relation("PIIAccessByAdmin", fields: [accessedByAdminId], references: [id])
  accessedByEmployee Employee? @relation("PIIAccessByEmployee", fields: [accessedByEmployeeId], references: [id])

  @@index([targetUserId, createdAt])
  @@index([accessedByAdminId, createdAt])
  @@index([accessedByEmployeeId, createdAt])
}

// ==========================
// 🏦 NACH/eNACH Mandate Management
// ==========================

enum NachMandateStatus {
  PENDING_REGISTRATION
  ACTIVE
  CANCELLED
  BOUNCED
  EXPIRED
  SUSPENDED
}

enum NachMandateType {
  NACH
  ENACH
  PHYSICAL
}

model NachMandate {
  id                String            @id @default(uuid())
  loanId            String
  userId            String
  umrn              String?           @unique  // Unique Mandate Reference Number
  mandateType       NachMandateType   @default(NACH)
  status            NachMandateStatus @default(PENDING_REGISTRATION)
  bankName          String
  bankBranch        String?
  accountNumber     String
  accountType       String            @default("SAVINGS") // SAVINGS, CURRENT
  ifscCode          String
  accountHolderName String
  maxAmount         Decimal
  frequency         String            @default("MONTHLY") // MONTHLY, QUARTERLY, YEARLY, AD_HOC
  startDate         DateTime
  endDate           DateTime?
  nextPresentationDate DateTime?
  retryCount        Int               @default(0)
  maxRetries        Int               @default(3)
  rejectionReason   String?
  registeredAt      DateTime?
  cancelledAt       DateTime?
  cancelledBy       String?
  cancelReason      String?
  metadata          Json?
  createdByAdminId    String?
  createdByEmployeeId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  loan              Loan              @relation(fields: [loanId], references: [id])
  user              User              @relation(fields: [userId], references: [id])
  bounceEvents      BounceEvent[]

  @@index([loanId, status])
  @@index([userId])
  @@index([umrn])
}

// ==========================
// 💸 Bounce Charge Recording
// ==========================

enum BounceEventType {
  NACH_BOUNCE
  CHEQUE_BOUNCE
  UPI_FAILURE
  NEFT_RETURN
}

model BounceEvent {
  id              String          @id @default(uuid())
  loanId          String
  emiId           String?
  mandateId       String?
  eventType       BounceEventType
  bounceDate      DateTime
  returnReason    String?
  bounceCharge    Decimal         @default(0)
  gstOnCharge     Decimal         @default(0)
  totalCharge     Decimal         @default(0)
  chargeCollected Boolean         @default(false)
  chargeCollectedAt DateTime?
  retryDate       DateTime?
  retryCount      Int             @default(0)
  instrumentNo    String?         // Cheque number / transaction ref
  bankRef         String?
  notes           String?
  recordedByAdminId    String?
  recordedByEmployeeId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  loan            Loan            @relation(fields: [loanId], references: [id])
  mandate         NachMandate?    @relation(fields: [mandateId], references: [id])

  @@index([loanId, bounceDate])
  @@index([mandateId])
}

// ==========================
// 📊 Month-End Portfolio Snapshot
// ==========================

model MonthEndSnapshot {
  id                    String   @id @default(uuid())
  snapshotDate          DateTime // Last day of the month
  month                 Int      // 1–12
  year                  Int
  totalLoans            Int      @default(0)
  activeLoans           Int      @default(0)
  overdueLoans          Int      @default(0)
  defaultedLoans        Int      @default(0)
  closedLoans           Int      @default(0)
  totalDisbursed        Decimal  @default(0)
  totalOutstanding      Decimal  @default(0)
  totalOverdue          Decimal  @default(0)
  totalCollected        Decimal  @default(0)
  npaAmount             Decimal  @default(0)  // Non-Performing Assets
  npaCount              Int      @default(0)
  writtenOffAmount      Decimal  @default(0)
  writtenOffCount       Int      @default(0)
  bucketCurrent         Int      @default(0)
  bucket0to30           Int      @default(0)
  bucket31to60          Int      @default(0)
  bucket61to90          Int      @default(0)
  bucket90Plus          Int      @default(0)
  loanTypeBreakdown     Json?    // { loanTypeId: { count, outstanding, overdue } }
  branchBreakdown       Json?    // { branchId: { count, outstanding, overdue } }
  generatedByAdminId    String?
  generatedByEmployeeId String?
  createdAt             DateTime @default(now())

  @@unique([month, year])
  @@index([year, month])
}

// ==========================
// 📨 Communication Templates
// ==========================

enum CommTemplateType {
  SMS
  EMAIL
  WHATSAPP
  PUSH_NOTIFICATION
}

enum CommTemplateCategory {
  EMI_DUE_REMINDER
  PAYMENT_CONFIRMATION
  OVERDUE_NOTICE
  LEGAL_NOTICE
  LOAN_APPROVAL
  LOAN_DISBURSAL
  KYC_REMINDER
  INSURANCE_EXPIRY
  WELCOME
  CUSTOM
}

model CommTemplate {
  id          String               @id @default(uuid())
  name        String
  type        CommTemplateType
  category    CommTemplateCategory
  subject     String?              // For email
  body        String               @db.Text
  variables   Json?                // [ { key: "borrowerName", description: "..." } ]
  isActive    Boolean              @default(true)
  language    String               @default("en")
  createdByAdminId    String?
  createdByEmployeeId String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  logs        CommLog[]

  @@index([type, category, isActive])
}

model CommLog {
  id           String   @id @default(uuid())
  templateId   String?
  loanId       String?
  userId       String?
  type         CommTemplateType
  recipient    String           // phone / email
  subject      String?
  body         String           @db.Text
  status       String           @default("PENDING") // PENDING, SENT, DELIVERED, FAILED
  failReason   String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  sentByAdminId    String?
  sentByEmployeeId String?
  createdAt    DateTime         @default(now())

  template     CommTemplate?    @relation(fields: [templateId], references: [id])

  @@index([loanId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// ==========================
// 📋 LoanType Rule Versioning
// ==========================

model LoanTypeRuleVersion {
  id          String   @id @default(uuid())
  loanTypeId  String
  version     Int
  rules       Json     // Full rules JSON snapshot
  changeNote  String?
  effectiveFrom DateTime @default(now())
  createdByAdminId    String?
  createdByEmployeeId String?
  createdAt   DateTime @default(now())

  loanType    LoanType @relation(fields: [loanTypeId], references: [id])

  @@unique([loanTypeId, version])
  @@index([loanTypeId, effectiveFrom])
}

// ==========================
// 🔢 Configurable Numbering Format
// ==========================

model NumberingFormat {
  id         String   @id @default(uuid())
  entityType String   @unique // FILE_NO, RECEIPT_NO, CUSTOMER_ID, EMPLOYEE_ID
  prefix     String?          // e.g. "KF", "RCP"
  suffix     String?
  separator  String   @default("-")
  padLength  Int      @default(6)  // Zero-pad length
  currentSeq Int      @default(0)
  resetMonthly Boolean @default(false)
  lastResetAt DateTime?
  example    String?  // Computed example: "KF-000001"
  updatedByAdminId String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

// ==========================
// 👥 Co-Borrower
// ==========================

model LoanCoBorrower {
  id                 String   @id @default(uuid())
  loanId             String
  userId             String
  isPrimary          Boolean  @default(false)
  incomeContribution Decimal?  // Monthly income contribution
  relationship       String?   // SPOUSE, PARENT, SIBLING, etc.
  kycVerified        Boolean  @default(false)
  consentGiven       Boolean  @default(false)
  consentAt          DateTime?
  addedByAdminId     String?
  addedByEmployeeId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  loan               Loan     @relation(fields: [loanId], references: [id])
  user               User     @relation("CoBorrowerUser", fields: [userId], references: [id])

  @@unique([loanId, userId])
  @@index([loanId])
  @@index([userId])
}

// ==========================
// 🧑‍💼 Underwriter Queue
// ==========================

enum UnderwriterTaskStatus {
  PENDING
  IN_REVIEW
  COMPLETED
  ESCALATED
  RETURNED
}

model UnderwriterTask {
  id                   String               @id @default(uuid())
  loanApplicationId    String?
  loanId               String?
  assignedToEmployeeId String?
  assignedByAdminId    String?
  status               UnderwriterTaskStatus @default(PENDING)
  priority             TaskPriority          @default(MEDIUM)
  notes                String?
  decisionComment      String?
  decisionAt           DateTime?
  dueDate              DateTime?
  escalatedAt          DateTime?
  escalationReason     String?
  metadata             Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  assignedToEmployee   Employee?             @relation("UnderwriterAssigned", fields: [assignedToEmployeeId], references: [id])

  @@index([assignedToEmployeeId, status])
  @@index([status, priority])
}

// ==========================
// ✅ Pre-Disbursal Checklist
// ==========================

model DisbursalChecklist {
  id                 String   @id @default(uuid())
  loanId             String   @unique
  items              Json     // [{ key, label, checked, blocking, checkedAt, checkedBy }]
  allBlockingCleared Boolean  @default(false)
  readyForDisbursal  Boolean  @default(false)
  clearedByAdminId    String?
  clearedByEmployeeId String?
  clearedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  loan               Loan     @relation(fields: [loanId], references: [id])
}

// ==========================
// ⏸️ Disbursal Hold
// ==========================

enum DisbursalHoldStatus {
  ACTIVE
  RELEASED
  CANCELLED
}

model DisbursalHold {
  id               String             @id @default(uuid())
  loanId           String
  reason           String
  holdType         String?            // COMPLIANCE, LEGAL, DOCUMENT_PENDING, MANUAL
  status           DisbursalHoldStatus @default(ACTIVE)
  placedByAdminId  String?
  placedByEmployeeId String?
  releasedByAdminId String?
  releasedByEmployeeId String?
  releaseNote      String?
  placedAt         DateTime           @default(now())
  releasedAt       DateTime?
  expiresAt        DateTime?
  metadata         Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  loan             Loan               @relation(fields: [loanId], references: [id])

  @@index([loanId, status])
}

// ==========================
// 🗄️ Data Retention & Archive
// ==========================

model ArchivedLog {
  id          String   @id @default(uuid())
  sourceTable String   // ActionLog, CommLog, PIIAccessLog, NotificationLog
  sourceId    String
  data        Json     // Full row snapshot
  archivedAt  DateTime @default(now())

  @@index([sourceTable, archivedAt])
}
