// ==========================
// 🔧 Prisma Configuration
// ==========================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================
// 📦 Enums
// ==========================

enum EmployeeRole {
  FINANCE_MANAGER
  SALES_EXECUTIVE
  SUPPORT_AGENT
}

// ==========================
// 📍 Location Models
// ==========================

model State {
  id   String @id @default(uuid())
  name String @unique
  city City[]

  employees   Employee[] // 🔁 back-relation for Employee.state
  userDetails UserDetails[] // 👈 new back-reference
  Region      Region[]
}

model City {
  id      String @id @default(uuid())
  name    String @unique
  stateId String
  state   State  @relation(fields: [stateId], references: [id])

  employees   Employee[] // 🔁 back-relation for Employee.city
  userDetails UserDetails[] // 👈 new back-reference
  Region      Region[]
}

model Region {
  id      String @id @default(uuid())
  name    String
  stateId String
  cityId  String

  state       State         @relation(fields: [stateId], references: [id])
  city        City          @relation(fields: [cityId], references: [id])
  userDetails UserDetails[] // 👈 new back-reference
  employees   Employee[]
}

// ==========================
// 👤 Identity & Roles
// ==========================

model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees          Employee[]
  loginActivities    LoginActivity[]
  terminationRequest TerminationRequest[]
  actionLogs         ActionLog[]
  users              User[]
  loans              Loan[]
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  permissions String[]
  employees   Employee[]
}

model Employee {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  adminId String?
  admin   Admin?  @relation(fields: [adminId], references: [id])

  stateId String?
  cityId  String?
  state   State?  @relation(fields: [stateId], references: [id])
  city    City?   @relation(fields: [cityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  isBlocked Boolean  @default(false)

  users              User[]
  loginActivities    LoginActivity[]
  actionLogs         ActionLog[]
  terminationRequest TerminationRequest[]
  loans              Loan[]
}

model LoginActivity {
  id         String   @id @default(uuid())
  adminId    String?
  employeeId String?
  role       String
  deviceName String?
  deviceType String?
  latitude   Float?
  longitude  Float?
  ipAddress  String?
  loggedInAt DateTime @default(now())

  admin      Admin?      @relation(fields: [adminId], references: [id])
  employee   Employee?   @relation(fields: [employeeId], references: [id])
  actionLogs ActionLog[]
}

model ActionLog {
  id              String  @id @default(uuid())
  adminId         String?
  employeeId      String?
  loginActivityId String?

  action    String
  targetId  String?
  table     String?
  metadata  Json?
  createdAt DateTime @default(now())

  admin         Admin?         @relation(fields: [adminId], references: [id])
  employee      Employee?      @relation(fields: [employeeId], references: [id])
  loginActivity LoginActivity? @relation(fields: [loginActivityId], references: [id])
}

// ==========================
// 👥 Users
// ==========================

model User {
  id          String    @id @default(uuid())
  name        String
  email       String?   @unique
  phone       String?   @unique
  otp         String?
  createdBy   String?
  adminId     String?
  employeeId  String?
  admin       Admin?    @relation(fields: [adminId], references: [id])
  employee    Employee? @relation(fields: [employeeId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isBlocked   Boolean   @default(false)
  isDefaulter Boolean   @default(false)

  details UserDetails?
  loans   Loan[]
}

model UserDetails {
  id            String  @id @default(uuid())
  userId        String  @unique
  photoIdNumber String  @unique
  photoIdTypeId String
  proofOfIncome String
  creditScore   Int?
  profession    String
  address       String?
  cityText      String?
  country       String
  photoId       String?

  // 🔁 Foreign keys now moved here:
  stateId  String?
  cityId   String?
  regionId String?

  state  State?  @relation(fields: [stateId], references: [id])
  city   City?   @relation(fields: [cityId], references: [id])
  region Region? @relation(fields: [regionId], references: [id])

  user        User        @relation(fields: [userId], references: [id])
  photoIdType PhotoIdType @relation(fields: [photoIdTypeId], references: [id])
  photo       File?       @relation("Photo", fields: [photoId], references: [id])

  photoIdTypeImages   File[] @relation("PhotoIdTypeImages")
  proofOfIncomeImages File[] @relation("ProofOfIncomeImages")
}

model PhotoIdType {
  id           String        @id @default(uuid())
  name         String        @unique
  description  String
  minLength    Int
  maxLength    Int
  numberTypeEg String
  validation   String?
  userDetails  UserDetails[]
}

// ==========================
// 💳 Loan & Payments
// ==========================

model LoanType {
  id          String  @id @default(uuid())
  name        String  @unique
  label       String
  description String?
  rules       Json?

  loans Loan[]
}

model Loan {
  id         String   @id @default(uuid())
  loanTypeId String
  loanType   LoanType @relation(fields: [loanTypeId], references: [id])

  amount       Float
  interestRate Float // e.g. 0.1 for 10%
  interestType String? // compound-yearly

  totalPayableAmount Float // Total with interest
  totalPaidAmount    Float @default(0)
  pendingAmount      Float // Updated after payment

  startDate     DateTime
  endDate       DateTime
  actualEndDate DateTime?
  tenureMonths  Int
  dueDay        Int       @default(5)

  isClosed       Boolean @default(false)
  isDefaulted    Boolean @default(false)
  totalDelayDays Int     @default(0)
  defaultReason  String?

  createdBy  String?
  adminId    String?
  employeeId String?
  userId     String

  admin    Admin?    @relation(fields: [adminId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  payments       Payment[]
  twoWheelerLoan TwoWheelerLoan?
  agriLoan       AgricultureLoan?
  msmeLoan       MSMELoan?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Payment {
  id              String   @id @default(uuid())
  loanId          String
  amount          Float
  paidOn          DateTime
  paymentFor      DateTime
  isDelayed       Boolean  @default(false)
  delayDays       Int?
  fineAmount      Float?
  mode            PaymentMode
  transactionId   String?
  verified        Boolean  @default(false)
  verifiedById    String?

  loan            Loan     @relation(fields: [loanId], references: [id])
  verifiedBy      Employee? @relation("VerifiedBy", fields: [verifiedById], references: [id])
}

enum PaymentMode {
  ONLINE
  CASH
}

// ==========================
// 🚘 Loan Sub-Types
// ==========================

model TwoWheelerLoan {
  id                 String  @id @default(uuid())
  loanId             String  @unique
  vehicleName        String
  brand              String
  model              String
  variant            String?
  registrationNumber String  @unique
  chassisNumber      String
  engineNumber       String
  rcNumber           String

  loan Loan @relation(fields: [loanId], references: [id])
}

model AgricultureLoan {
  id         String  @id @default(uuid())
  loanId     String  @unique
  equipment  String
  usageArea  String
  isSeasonal Boolean @default(false)

  loan Loan @relation(fields: [loanId], references: [id])
}

model MSMELoan {
  id                 String  @id @default(uuid())
  loanId             String  @unique
  businessName       String
  registrationNumber String  @unique
  businessType       String
  monthlyRevenue     Float
  gstNumber          String?

  loan Loan @relation(fields: [loanId], references: [id])
}

// ==========================
// 📑 Termination / Files
// ==========================

model TerminationRequest {
  id            String   @id @default(uuid())
  regnNo        String
  chassisNo     String
  terminationDt DateTime
  docFileId     String?
  docFile       File?    @relation(fields: [docFileId], references: [id])
  encryptedData String
  response      Json?
  status        String?
  errorMessage  String?

  createdAt  DateTime @default(now())
  createdBy  String?
  adminId    String?
  employeeId String?

  admin    Admin?    @relation(fields: [adminId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])
}

model File {
  id           String   @id @default(uuid())
  url          String
  publicId     String
  resourceType String
  format       String
  createdAt    DateTime @default(now())

  terminationRequest  TerminationRequest[]
  photo               UserDetails[]        @relation("Photo")
  photoIdTypeImages   UserDetails[]        @relation("PhotoIdTypeImages")
  proofOfIncomeImages UserDetails[]        @relation("ProofOfIncomeImages")
}
