  overdueEmiCount      Int                  @default(0)
  overdueAmount        Decimal              @default(0)
  overdueFineAmount    Decimal              @default(0)
  totalDue             Decimal              @default(0)
  oldestDueDate        DateTime?
  nextActionAt         DateTime?
  lastContactAt        DateTime?
  latestPromiseDate    DateTime?
  latestPromiseAmount  Decimal?
  resolutionType       String?
  notes                String?
  metadata             Json?
  assignedToEmployeeId String?
  createdByAdminId     String?
  createdByEmployeeId  String?
  assignedByAdminId    String?
  assignedByEmployeeId String?
  closedByAdminId      String?
  closedByEmployeeId   String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  loan               Loan               @relation(fields: [loanId], references: [id], onDelete: Cascade)
  branch             Branch?            @relation(fields: [branchId], references: [id])
