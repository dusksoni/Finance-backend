  createdByAdmin    Admin?          @relation("GrievanceCommentCreatedByAdmin", fields: [createdByAdminId], references: [id])
  createdByEmployee Employee?       @relation("GrievanceCommentCreatedByEmployee", fields: [createdByEmployeeId], references: [id])

  @@index([ticketId, createdAt])
