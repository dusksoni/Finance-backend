# ─── Finance SaaS — Environment Variables ────────────────────────────────────
# Copy this to .env for each NBFC deployment. Each NBFC gets its own instance.

# App
COMPANY_NAME=MyNBFC
NODE_ENV=production
PORT=3001
APP_VERSION=1.0.0

# Database — one DB per NBFC deployment
DATABASE_URL=postgresql://user:password@host:port/database

# Auth
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
SECRET_KEY=your_secret_key_here

# MSG91 Configuration (SMS/OTP) - Replaces Twilio
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_SENDER_ID=KSHFIN

# Twilio Configuration (DEPRECATED - Use MSG91 instead)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# Vahan API (Hypothecation Termination)
SECRET_KEY_TERMINATE=your_vahan_secret_key
CLIENT_ID_TERMINATE=your_vahan_client_id
USER_PWD_TERMINATE=your_vahan_password

# Cloudinary (File Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ICICI UPI/QR Payment Gateway Configuration
# Merchant credentials provided by ICICI
ICICI_MERCHANT_ID=your_merchant_id
ICICI_SUB_MERCHANT_ID=your_sub_merchant_id
ICICI_TERMINAL_ID=5411
ICICI_API_KEY=your_api_key

# Gateway URLs
# UAT: https://apibankingonesandbox.icicibank.com
# Production: https://apibankingone.icicibank.com
ICICI_GATEWAY_URL=https://apibankingonesandbox.icicibank.com

# Merchant VPA (Virtual Payment Address) provided by ICICI
ICICI_MERCHANT_VPA=merchant@icici
ICICI_MERCHANT_NAME=Kushal Finance

# Callback URL - ICICI will send payment status here
# This should be publicly accessible (use ngrok for local testing)
ICICI_CALLBACK_URL=https://your-domain.com/api/icici-payment/callback

# Orange PG / ICICI PayPhi (alternative gateway config)
ORANGE_PG_MERCHANT_ID=
ORANGE_PG_SECRET_KEY=
ORANGE_PG_AGGREGATOR_ID=
ORANGE_PG_CURRENCY_CODE=356
ORANGE_PG_API_URL=https://qa.phicommerce.com/pg/api/v2
ORANGE_PG_RETURN_URL=https://your-domain.com/api/icici-payment/callback

# Surepass (CIBIL / credit bureau aggregator)
# Contact Surepass to get API credentials and sandbox access
# Also configurable via admin panel: NBFC Settings → Credit & CIBIL
SUREPASS_API_TOKEN=

# Sentry (error monitoring — free tier at sentry.io)
SENTRY_DSN=

# Grafana admin password (used in docker-compose)
GRAFANA_PASSWORD=changeme
