generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeRole {
  FINANCE_MANAGER
  SALES_EXECUTIVE
  SUPPORT_AGENT
}

enum LoanType {
  TWOWHEELER
  AGRICULTURE
}

model Admin {
  id               String             @id @default(uuid())
  name             String
  email            String             @unique
  password         String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  employees        Employee[]
  loginActivities  LoginActivity[]
  terminationRequest  TerminationRequest[]
  actionLogs       ActionLog[]
  users            User[]
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  permissions String[]

  employees   Employee[]
}


model Employee {
  id         String     @id @default(uuid())
  name       String
  email      String     @unique
  password   String

  roleId     String?
  role       Role?        @relation(fields: [roleId], references: [id])

  adminId    String?
  admin      Admin?      @relation(fields: [adminId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  isDeleted  Boolean  @default(false) // 👈 Add this
  isBlocked  Boolean  @default(false) // 👈 Add this
  users      User[]
  loginActivities  LoginActivity[]
  actionLogs       ActionLog[]
  terminationRequest  TerminationRequest[]
}


model ActionLog {
  id              String   @id @default(uuid())
  adminId         String?
  employeeId      String?
  loginActivityId String?

  action          String
  targetId        String?
  table           String?
  metadata        Json?
  createdAt       DateTime @default(now())

  admin           Admin?     @relation(fields: [adminId], references: [id])
  employee        Employee?  @relation(fields: [employeeId], references: [id])
  loginActivity   LoginActivity? @relation(fields: [loginActivityId], references: [id])
}


model LoginActivity {
  id            String     @id @default(uuid())
  adminId       String?
  employeeId    String?
  role          String
  deviceName    String?
  deviceType    String?
  latitude      Float?
  longitude     Float?
  ipAddress     String?
  loggedInAt    DateTime   @default(now())

  admin         Admin?     @relation(fields: [adminId], references: [id])
  employee      Employee?  @relation(fields: [employeeId], references: [id])
  actionLogs    ActionLog[]  // 👈 This lets you track which actions were done in each login
}


model User {
  id          String     @id @default(uuid())
  name        String
  email       String?    @unique
  phone       String?    @unique
  otp         String?
  createdBy   String?
  adminId     String?
  employeeId  String?
  admin       Admin?     @relation(fields: [adminId], references: [id])
  employee    Employee?  @relation(fields: [employeeId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isDefaulter Boolean    @default(false)
  details     UserDetails?
  loans       Loan[]
}

model PhotoIdType {
  id           String         @id @default(uuid())
  name         String         @unique
  description  String
  minLength    Int
  maxLength    Int
  numberTypeEg String
  validation   String?        // Regex or format note
  userDetails  UserDetails[]
}


model UserDetails {
  id                  String    @id @default(uuid())
  userId              String    @unique
  photoIdNumber       String    @unique
  photoIdTypeId       String
  photoIdType         PhotoIdType? @relation(fields: [photoIdTypeId], references: [id])
  photoIdTypeImage    String[]  // Array of image URLs or file paths
  proofOfIncome       String
  proofOfIncomeImage  String[]  // Array of image URLs or file paths
  creditScore         Int?
  profession          String
  address             String?
  photoUrl            String?   // Optional profile photo
  user                User      @relation(fields: [userId], references: [id])
}

model Loan {
  id            String     @id @default(uuid())
  userId        String
  type          LoanType
  amount        Float
  interestRate  Float      @default(0.05)
  startDate     DateTime
  dueDay        Int        @default(5)
  isClosed      Boolean    @default(false)

  user          User       @relation(fields: [userId], references: [id])
  payments      Payment[]
  twoWheelerLoan TwoWheelerLoan?
  agriLoan       AgricultureLoan?
}

model Payment {
  id         String   @id @default(uuid())
  loanId     String
  amount     Float
  paidOn     DateTime
  paymentFor DateTime
  loan       Loan     @relation(fields: [loanId], references: [id])
}

model TwoWheelerLoan {
  id                  String   @id @default(uuid())
  loanId              String   @unique
  vehicleType         String
  brand               String
  model               String
  dealerName          String
  registrationNumber  String
  loan                Loan     @relation(fields: [loanId], references: [id])
}

model AgricultureLoan {
  id         String   @id @default(uuid())
  loanId     String   @unique
  equipment  String
  loan       Loan     @relation(fields: [loanId], references: [id])
}


model TerminationRequest {
  id             String   @id @default(uuid())
  regnNo         String
  chassisNo      String
  terminationDt  DateTime
  docFileId     String?
  docFile       File?    @relation(fields: [docFileId], references: [id])
  encryptedData  String
  response       Json?
  status         String?     // optional: e.g. "SUCCESS", "FAILED"
  errorMessage   String?     // optional: capture failure reason if any

  createdAt      DateTime @default(now())
  createdBy      String?       // Admin or Employee ID
  adminId        String?
  employeeId     String?

  admin          Admin?     @relation(fields: [adminId], references: [id])
  employee       Employee?  @relation(fields: [employeeId], references: [id])
}

model File {
  id                String   @id @default(uuid())
  url               String
  publicId          String
  resourceType      String   // e.g., image, raw, video
  format            String   // e.g., jpg, png, pdf
  createdAt         DateTime @default(now())
  terminationRequest    TerminationRequest[]
}