					"name": "Admin Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.token) {",
									"        pm.collectionVariables.set('authToken', response.token);",
									"        console.log('Token saved:', response.token);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
